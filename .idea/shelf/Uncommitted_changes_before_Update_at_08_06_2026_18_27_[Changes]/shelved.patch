<+><!DOCTYPE html>\r\n<html lang=\"pt-BR\">\r\n<head>\r\n    <meta charset=\"UTF-8\">\r\n    <meta name=\"viewport\" content=\"width=device-width, initial-scale=1.0\">\r\n    <title>Nexus – SIMPA</title>\r\n    <link rel=\"preconnect\" href=\"https://fonts.googleapis.com\">\r\n    <link rel=\"preconnect\" href=\"https://fonts.gstatic.com\" crossorigin>\r\n    <link href=\"https://fonts.googleapis.com/css2?family=Plus+Jakarta+Sans:wght@300;400;500;600;700&display=swap\" rel=\"stylesheet\">\r\n    <script src=\"https://cdn.jsdelivr.net/npm/chart.js@4.4.0/dist/chart.umd.min.js\"></script>\r\n    <style>\r\n        :root {\r\n            --primary: #6366f1;\r\n            --primary-glow: rgba(99,102,241,0.2);\r\n            --accent: #f43f5e;\r\n            --success: #10b981;\r\n            --warning: #f59e0b;\r\n            --info: #38bdf8;\r\n            --bg-dark: #F0F4FF;\r\n            --glass-bg: #FFFFFF;\r\n            --glass-border: rgba(148,163,184,0.25);\r\n            --text-main: #0f172a;\r\n            --text-dim: #64748b;\r\n            --sidebar-w: 270px;\r\n        }\r\n        *{margin:0;padding:0;box-sizing:border-box;font-family:'Plus Jakarta Sans',sans-serif}\r\n        body{background:var(--bg-dark);color:var(--text-main);min-height:100vh;display:flex;overflow-x:hidden}\r\n\r\n        .bg-glow{position:fixed;width:600px;height:600px;border-radius:50%;z-index:-1;filter:blur(80px);opacity:.2;pointer-events:none}\r\n        .glow-1{top:-200px;right:-200px;background:radial-gradient(circle,var(--primary-glow) 0%,transparent 70%)}\r\n        .glow-2{bottom:-200px;left:-200px;background:radial-gradient(circle,rgba(244,63,94,.15) 0%,transparent 70%)}\r\n\r\n        /* ── Sidebar ── */\r\n        aside{width:var(--sidebar-w);background:rgba(255,255,255,.97);backdrop-filter:blur(20px);border-right:1px solid var(--glass-border);height:100vh;position:fixed;top:0;left:0;display:flex;flex-direction:column;padding:2rem;z-index:300;flex-shrink:0;transform:translateX(calc(-1 * var(--sidebar-w)));transition:transform .3s cubic-bezier(.4,0,.2,1)}\r\n        aside.open{transform:translateX(0)}\r\n        .sidebar-backdrop{display:none;position:fixed;inset:0;background:rgba(0,0,0,.55);backdrop-filter:blur(2px);z-index:299}\r\n        .sidebar-backdrop.open{display:block}\r\n        .logo-toggle{position:fixed;top:1.25rem;left:1.25rem;z-index:200;width:38px;height:38px;background:linear-gradient(135deg,var(--primary),var(--accent));border-radius:12px;display:flex;align-items:center;justify-content:center;cursor:pointer;box-shadow:0 0 18px var(--primary-glow);border:none;color:#fff;transition:transform .2s,box-shadow .2s}\r\n        .logo-toggle:hover{transform:scale(1.08);box-shadow:0 0 26px var(--primary-glow)}\r\n        .logo-area{display:flex;align-items:center;gap:.9rem;margin-bottom:2.5rem;cursor:pointer}\r\n        .logo-box{width:38px;height:38px;background:linear-gradient(135deg,var(--primary),var(--accent));border-radius:12px;display:flex;align-items:center;justify-content:center;box-shadow:0 0 18px var(--primary-glow);flex-shrink:0}\r\n        .logo-text{font-size:1.4rem;font-weight:800;letter-spacing:-1px;background:linear-gradient(to right,#1e293b,#475569);-webkit-background-clip:text;background-clip:text;-webkit-text-fill-color:transparent}\r\n        .nav-links{list-style:none;flex:1}\r\n        .nav-item{margin-bottom:.3rem}\r\n        .nav-link{display:flex;align-items:center;gap:.85rem;padding:.7rem 1rem;color:var(--text-dim);text-decoration:none;border-radius:12px;transition:all .2s;font-weight:500;font-size:.875rem;cursor:pointer;border:1px solid transparent}\r\n        .nav-link svg{width:18px;height:18px;flex-shrink:0}\r\n        .nav-link:hover{background:rgba(99,102,241,.06);color:var(--text-main);border-color:rgba(99,102,241,.15)}\r\n        .nav-link.active{background:rgba(99,102,241,.08);color:var(--primary);border-color:rgba(99,102,241,.2)}\r\n        .nav-section{font-size:.7rem;text-transform:uppercase;letter-spacing:.1em;color:var(--text-dim);padding:.75rem 1rem .25rem;opacity:.55}\r\n        .user-profile{padding-top:1.5rem;border-top:1px solid var(--glass-border);display:flex;align-items:center;gap:.85rem}\r\n        .avatar{width:38px;height:38px;border-radius:50%;background:var(--glass-bg);border:1px solid var(--glass-border);display:flex;align-items:center;justify-content:center;flex-shrink:0}\r\n\r\n        /* ── Main ── */\r\n        main{flex:1;padding:2rem 2.5rem;padding-left:5rem;overflow-y:auto;min-width:0}\r\n        .top-bar{display:flex;justify-content:space-between;align-items:center;margin-bottom:2rem;flex-wrap:wrap;gap:1rem}\r\n        .top-bar h1{font-size:1.75rem;font-weight:700}\r\n        .top-bar p{color:var(--text-dim);font-size:.875rem;margin-top:.2rem}\r\n        .top-bar-actions{display:flex;gap:.75rem;align-items:center;flex-wrap:wrap}\r\n\r\n        /* ── Cards KPI ── */\r\n        .kpi-grid{display:grid;grid-template-columns:repeat(auto-fill,minmax(190px,1fr));gap:1.25rem;margin-bottom:2rem}\r\n        .kpi-card{background:var(--glass-bg);border:1px solid var(--glass-border);border-radius:20px;padding:1.25rem 1.5rem;transition:transform .25s,border-color .25s;box-shadow:0 2px 8px rgba(0,0,0,.06)}\r\n        .kpi-card:hover{transform:translateY(-4px);border-color:rgba(99,102,241,.25)}\r\n        .kpi-icon{width:40px;height:40px;border-radius:12px;display:flex;align-items:center;justify-content:center;margin-bottom:.85rem}\r\n        .kpi-value{font-size:1.6rem;font-weight:700;line-height:1}\r\n        .kpi-label{color:var(--text-dim);font-size:.78rem;font-weight:500;margin-top:.3rem}\r\n        .kpi-sub{font-size:.7rem;color:var(--text-dim);margin-top:.15rem;opacity:.7}\r\n        .icon-blue{background:rgba(59,130,246,.12);color:#60a5fa}\r\n        .icon-emerald{background:rgba(16,185,129,.12);color:#34d399}\r\n        .icon-rose{background:rgba(244,63,94,.12);color:#fb7185}\r\n        .icon-amber{background:rgba(245,158,11,.12);color:#fbbf24}\r\n        .icon-sky{background:rgba(56,189,248,.12);color:#38bdf8}\r\n        .icon-violet{background:rgba(139,92,246,.12);color:#a78bfa}\r\n\r\n        /* ── Blocos ── */\r\n        .grid-2{display:grid;grid-template-columns:2fr 1fr;gap:1.25rem;margin-bottom:1.5rem}\r\n        .grid-2-eq{display:grid;grid-template-columns:1fr 1fr;gap:1.25rem;margin-bottom:1.5rem}\r\n        .block{background:var(--glass-bg);border:1px solid var(--glass-border);border-radius:22px;padding:1.75rem;margin-bottom:1.5rem;box-shadow:0 2px 10px rgba(0,0,0,.06)}\r\n        .block:last-child{margin-bottom:0}\r\n        .block-header{display:flex;justify-content:space-between;align-items:flex-start;margin-bottom:1.5rem;flex-wrap:wrap;gap:.75rem}\r\n        .block-title{font-size:1rem;font-weight:600}\r\n        .block-sub{font-size:.75rem;color:var(--text-dim);margin-top:.2rem}\r\n\r\n        /* ── Tabelas ── */\r\n        .table-wrap{overflow-x:auto}\r\n        table{width:100%;border-collapse:collapse;font-size:.83rem}\r\n        th{text-align:left;padding:.85rem 1rem;color:var(--text-dim);font-weight:500;border-bottom:1px solid var(--glass-border);white-space:nowrap}\r\n        td{padding:.85rem 1rem;border-bottom:1px solid var(--glass-border);vertical-align:middle}\r\n        tr:last-child td{border-bottom:none}\r\n        tr:hover td{background:rgba(0,0,0,.02)}\r\n\r\n        /* ── Badges ── */\r\n        .badge{padding:.2rem .65rem;border-radius:20px;font-size:.7rem;font-weight:600;white-space:nowrap}\r\n        .badge-baixo{background:rgba(16,185,129,.15);color:#34d399}\r\n        .badge-medio{background:rgba(245,158,11,.15);color:#fbbf24}\r\n        .badge-alto{background:rgba(244,63,94,.15);color:#fb7185}\r\n        .badge-critico{background:rgba(220,38,38,.2);color:#f87171}\r\n\r\n        /* ── Z-score bar ── */\r\n        .zscore-bar{display:flex;align-items:center;gap:.5rem}\r\n        .zscore-track{flex:1;height:4px;background:rgba(0,0,0,.1);border-radius:2px}\r\n        .zscore-fill{height:100%;border-radius:2px}\r\n\r\n        /* ── Botões ── */\r\n        .btn{padding:.5rem 1rem;border-radius:10px;border:1px solid var(--glass-border);background:var(--glass-bg);color:var(--text-main);cursor:pointer;font-weight:500;font-size:.82rem;transition:all .2s;white-space:nowrap}\r\n        .btn:hover{background:rgba(0,0,0,.04)}\r\n        .btn-primary{background:var(--primary);border-color:var(--primary);color:#fff}\r\n        .btn-primary:hover{background:#4f46e5}\r\n        .btn-danger{background:rgba(244,63,94,.15);border-color:rgba(244,63,94,.3);color:#fb7185}\r\n        .btn-danger:hover{background:rgba(244,63,94,.25)}\r\n        .btn-sm{padding:.3rem .7rem;font-size:.75rem;border-radius:8px}\r\n        .btn-group{display:flex;gap:.4rem;flex-wrap:nowrap}\r\n\r\n        /* ── Formulários ── */\r\n        .form-group{margin-bottom:1rem}\r\n        .form-group label{display:block;margin-bottom:.4rem;font-size:.78rem;color:var(--text-dim)}\r\n        .form-control{width:100%;padding:.6rem .9rem;border-radius:10px;border:1px solid var(--glass-border);background:#F8FAFC;color:var(--text-main);font-size:.875rem;outline:none;transition:border-color .2s}\r\n        .form-control:focus{border-color:var(--primary)}\r\n        .form-control option{background:#FFFFFF;color:#0f172a}\r\n        .form-row{display:grid;grid-template-columns:1fr 1fr;gap:.75rem}\r\n\r\n        /* ── Modais ── */\r\n        .modal-bg{display:none;position:fixed;inset:0;background:rgba(0,0,0,.75);z-index:200;align-items:center;justify-content:center}\r\n        .modal-bg.open{display:flex}\r\n        .modal-box{background:#FFFFFF;border:1px solid var(--glass-border);border-radius:22px;padding:2rem;width:460px;max-width:95vw;max-height:90vh;overflow-y:auto;animation:fadeIn .2s ease-out;box-shadow:0 20px 50px rgba(0,0,0,.12)}\r\n        .modal-title{font-size:1.15rem;font-weight:600;margin-bottom:1.5rem}\r\n        .modal-footer{display:flex;gap:.75rem;justify-content:flex-end;margin-top:1.5rem}\r\n\r\n        /* ── Correlação badge ── */\r\n        .corr-badge{display:inline-flex;align-items:center;gap:.4rem;padding:.35rem .85rem;border-radius:20px;font-size:.75rem;font-weight:600;border:1px solid}\r\n        .corr-pos{background:rgba(16,185,129,.1);color:#34d399;border-color:rgba(16,185,129,.25)}\r\n        .corr-neg{background:rgba(244,63,94,.1);color:#fb7185;border-color:rgba(244,63,94,.25)}\r\n\r\n        /* ── Legend ── */\r\n        .legend-row{display:flex;gap:1rem;flex-wrap:wrap;margin-top:1rem}\r\n        .legend-item{display:flex;align-items:center;gap:.4rem;font-size:.75rem;color:var(--text-dim)}\r\n        .legend-dot{width:10px;height:10px;border-radius:50%;flex-shrink:0}\r\n\r\n        /* ── Empty state ── */\r\n        .empty-state{text-align:center;padding:4rem 2rem;color:var(--text-dim)}\r\n        .empty-state svg{margin-bottom:1rem;opacity:.4}\r\n        .empty-state p{font-size:.9rem}\r\n\r\n        /* ── Breadcrumb ── */\r\n        .breadcrumb-bar{display:flex;align-items:center;gap:.75rem;margin-bottom:1.5rem;padding:.65rem 1.1rem;background:var(--glass-bg);border:1px solid var(--glass-border);border-radius:14px}\r\n        .breadcrumb-bar button{background:none;border:none;color:var(--primary);cursor:pointer;font-size:.83rem;font-weight:600;padding:0;display:flex;align-items:center;gap:.4rem}\r\n        .breadcrumb-bar button:hover{text-decoration:underline}\r\n        .breadcrumb-sep{color:var(--text-dim);opacity:.4;font-size:.9rem}\r\n        .breadcrumb-current{color:var(--text-dim);font-size:.83rem}\r\n        .turma-row:hover td{background:rgba(99,102,241,.07);cursor:pointer}\r\n\r\n        /* ── Animações ── */\r\n        @keyframes fadeIn{from{opacity:0;transform:translateY(8px)}to{opacity:1;transform:translateY(0)}}\r\n        .view{animation:fadeIn .3s ease-out}\r\n\r\n        /* ── Responsivo ── */\r\n        @media(max-width:1200px){.grid-2{grid-template-columns:1fr}.grid-2-eq{grid-template-columns:1fr}}\r\n        @media(max-width:800px){main{padding:1.25rem;padding-left:4.5rem}}\r\n\r\n        /* ── Toggle de Tema ── */\r\n        .theme-toggle{position:fixed;top:4.5rem;left:1.25rem;z-index:200;width:38px;height:38px;background:var(--glass-bg);border:1px solid var(--glass-border);border-radius:12px;display:flex;align-items:center;justify-content:center;cursor:pointer;color:var(--text-dim);transition:all .2s;box-shadow:0 2px 8px rgba(0,0,0,.08)}\r\n        .theme-toggle:hover{color:var(--primary);border-color:rgba(99,102,241,.3)}\r\n\r\n        /* ── Tema Escuro ── */\r\n        [data-theme=\"dark\"]{\r\n            --bg-dark:#0f172a;\r\n            --glass-bg:rgba(255,255,255,0.04);\r\n            --glass-border:rgba(255,255,255,0.08);\r\n            --text-main:#f8fafc;\r\n            --text-dim:#94a3b8;\r\n            --primary-glow:rgba(99,102,241,0.45);\r\n        }\r\n        [data-theme=\"dark\"] aside{background:rgba(15,23,42,.95)}\r\n        [data-theme=\"dark\"] .logo-text{background-image:linear-gradient(to right,#fff,#94a3b8)}\r\n        [data-theme=\"dark\"] .nav-link:hover{background:var(--glass-bg);color:#fff;border-color:var(--glass-border)}\r\n        [data-theme=\"dark\"] .nav-link.active{background:var(--glass-bg);color:#fff;border-color:var(--glass-border)}\r\n        [data-theme=\"dark\"] tr:hover td{background:rgba(255,255,255,.02)}\r\n        [data-theme=\"dark\"] .zscore-track{background:rgba(255,255,255,.08)}\r\n        [data-theme=\"dark\"] .btn{color:#fff}\r\n        [data-theme=\"dark\"] .btn:hover{background:rgba(255,255,255,.08)}\r\n        [data-theme=\"dark\"] .btn-primary{color:#fff}\r\n        [data-theme=\"dark\"] .form-control{background:rgba(255,255,255,.05);color:#fff}\r\n        [data-theme=\"dark\"] .form-control option{background:#1e293b;color:#fff}\r\n        [data-theme=\"dark\"] .modal-box{background:#1e293b;box-shadow:none}\r\n        [data-theme=\"dark\"] .bg-glow{opacity:.35}\r\n        [data-theme=\"dark\"] .kpi-card{box-shadow:none}\r\n        [data-theme=\"dark\"] .block{box-shadow:none}\r\n        [data-theme=\"dark\"] .theme-toggle{box-shadow:none}\r\n    </style>\r\n</head>\r\n<body>\r\n<div class=\"bg-glow glow-1\"></div>\r\n<div class=\"bg-glow glow-2\"></div>\r\n\r\n<!-- ════════════════ SIDEBAR ════════════════ -->\r\n<div class=\"sidebar-backdrop\" id=\"sidebarBackdrop\" onclick=\"closeSidebar()\"></div>\r\n<button class=\"logo-toggle\" id=\"logoToggle\" onclick=\"toggleSidebar()\" aria-label=\"Abrir menu\">\r\n    <svg width=\"22\" height=\"22\" viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"2.5\" stroke-linecap=\"round\" stroke-linejoin=\"round\"><path d=\"M13 2L3 14h9l-1 8 10-12h-9l1-8z\"/></svg>\r\n</button>\r\n<button class=\"theme-toggle\" id=\"themeToggle\" aria-label=\"Alternar tema\">\r\n    <svg id=\"themeIcon\" width=\"18\" height=\"18\" viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"2\" stroke-linecap=\"round\" stroke-linejoin=\"round\">\r\n        <path d=\"M21 12.79A9 9 0 1 1 11.21 3 7 7 0 0 0 21 12.79z\"/>\r\n    </svg>\r\n</button>\r\n<aside id=\"sidebar\">\r\n    <div class=\"logo-area\" onclick=\"closeSidebar()\">\r\n        <div class=\"logo-box\">\r\n            <svg width=\"22\" height=\"22\" viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"2.5\" stroke-linecap=\"round\" stroke-linejoin=\"round\"><path d=\"M13 2L3 14h9l-1 8 10-12h-9l1-8z\"/></svg>\r\n        </div>\r\n        <span class=\"logo-text\">NEXUS</span>\r\n    </div>\r\n\r\n    <ul class=\"nav-links\">\r\n        <li class=\"nav-section\">Principal</li>\r\n        <li class=\"nav-item\">\r\n            <a class=\"nav-link active\" data-view=\"dashboard\" onclick=\"showView('dashboard');return false\">\r\n                <svg viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"2\"><rect x=\"3\" y=\"3\" width=\"7\" height=\"7\"/><rect x=\"14\" y=\"3\" width=\"7\" height=\"7\"/