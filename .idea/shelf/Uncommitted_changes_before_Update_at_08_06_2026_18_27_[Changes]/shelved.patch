>\r\n            </div>\r\n        </div>\r\n\r\n    </div>\r\n\r\n    <!-- ══ VIEW: ALUNOS ══ -->\r\n    <div id=\"view-alunos\" class=\"view\" style=\"display:none\">\r\n        <div class=\"block\">\r\n            <div class=\"block-header\">\r\n                <div><div class=\"block-title\">Lista de Alunos</div><div class=\"block-sub\" id=\"alunosCount\">Carregando...</div></div>\r\n                <div class=\"btn-group\">\r\n                    <input type=\"text\" id=\"alunoSearch\" class=\"btn\" placeholder=\"Buscar...\" style=\"width:200px;text-align:left\">\r\n                    <button class=\"btn btn-primary\" onclick=\"abrirModal('modalNovoAluno')\">+ Novo Aluno</button>\r\n                </div>\r\n            </div>\r\n            <div class=\"table-wrap\">\r\n                <table>\r\n                    <thead><tr>\r\n                        <th>Nome</th><th>Matrícula</th><th>Curso</th><th>Período</th><th>E-mail</th><th>Ações</th>\r\n                    </tr></thead>\r\n                    <tbody id=\"alunosBody\"></tbody>\r\n                </table>\r\n            </div>\r\n        </div>\r\n    </div>\r\n\r\n    <!-- ══ VIEW: ALERTAS ══ -->\r\n    <div id=\"view-alertas\" class=\"view\" style=\"display:none\">\r\n        <div class=\"kpi-grid\" id=\"alertKpis\" style=\"grid-template-columns:repeat(3,1fr)\">\r\n            <div class=\"kpi-card\"><div class=\"kpi-icon icon-rose\"><svg width=\"20\" height=\"20\" viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"2\"><path d=\"M10.29 3.86L1.82 18a2 2 0 0 0 1.71 3h16.94a2 2 0 0 0 1.71-3L13.71 3.86a2 2 0 0 0-3.42 0z\"/></svg></div><div class=\"kpi-value\" id=\"aKCritico\">--</div><div class=\"kpi-label\">Críticos</div></div>\r\n            <div class=\"kpi-card\"><div class=\"kpi-icon icon-amber\"><svg width=\"20\" height=\"20\" viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"2\"><circle cx=\"12\" cy=\"12\" r=\"10\"/><line x1=\"12\" y1=\"8\" x2=\"12\" y2=\"12\"/><line x1=\"12\" y1=\"16\" x2=\"12.01\" y2=\"16\"/></svg></div><div class=\"kpi-value\" id=\"aKAlto\">--</div><div class=\"kpi-label\">Alta Prioridade</div></div>\r\n            <div class=\"kpi-card\"><div class=\"kpi-icon icon-sky\"><svg width=\"20\" height=\"20\" viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"2\"><path d=\"M18 8A6 6 0 0 0 6 8c0 7-3 9-3 9h18s-3-2-3-9\"/><path d=\"M13.73 21a2 2 0 0 1-3.46 0\"/></svg></div><div class=\"kpi-value\" id=\"aKMedio\">--</div><div class=\"kpi-label\">Atenção</div></div>\r\n        </div>\r\n        <div class=\"block\">\r\n            <div class=\"block-header\">\r\n                <div><div class=\"block-title\">Alertas Ativos</div><div class=\"block-sub\">Padrões de risco detectados automaticamente</div></div>\r\n                <select id=\"alertFiltro\" class=\"btn\" onchange=\"filtrarAlertas()\">\r\n                    <option value=\"\">Todos os níveis</option>\r\n                    <option value=\"critico\">Crítico</option>\r\n                    <option value=\"alto\">Alto</option>\r\n                    <option value=\"medio\">Médio</option>\r\n                </select>\r\n            </div>\r\n            <div id=\"alertasLista\"></div>\r\n        </div>\r\n    </div>\r\n\r\n    <!-- ══ VIEW: IMPORTAR PLANILHA ══ -->\r\n    <div id=\"view-importar\" class=\"view\" style=\"display:none\">\r\n        <div class=\"block\">\r\n            <div class=\"block-header\">\r\n                <div>\r\n                    <div class=\"block-title\">Importar de Planilha Google</div>\r\n                    <div class=\"block-sub\" style=\"font-weight: 600;\">Carregue dados de uma planilha pública do Google Sheets e configure o mapeamento de colunas (De-Para).</div>\r\n                </div>\r\n            </div>\r\n            \r\n            <!-- Etapa 1: URL da planilha -->\r\n            <div id=\"import-step-url\">\r\n                <div class=\"form-group\" style=\"margin-bottom: 1.5rem;\">\r\n                    <label style=\"font-weight: 600; margin-bottom: 0.5rem; display: block;\">Link da Planilha Google Pública *</label>\r\n                    <input type=\"url\" id=\"sheetUrl\" class=\"form-control\" placeholder=\"https://docs.google.com/spreadsheets/d/.../edit?usp=sharing\" style=\"margin-bottom: 1rem; width: 100%;\">\r\n                </div>\r\n                <button class=\"btn btn-primary\" onclick=\"analisarPlanilha()\">Analisar Planilha</button>\r\n            </div>\r\n\r\n            <!-- Carregando... -->\r\n            <div id=\"import-loading\" style=\"display:none; text-align:center; padding: 3rem 1rem;\">\r\n                <div style=\"font-size: 1.1rem; font-weight: 700; margin-bottom: 0.5rem; color: var(--primary);\">Buscando e processando a planilha...</div>\r\n                <div style=\"color: var(--text-dim); font-size: 0.85rem;\">Isso pode levar alguns segundos para planilhas grandes.</div>\r\n            </div>\r\n\r\n            <!-- Etapa 2: Mapeamento \"De-Para\" e Preview -->\r\n            <div id=\"import-step-mapping\" style=\"display:none;\">\r\n                <input type=\"hidden\" id=\"tempImportId\">\r\n                \r\n                <h3 style=\"font-size: 1.05rem; font-weight: 700; margin: 2rem 0 1rem 0; padding-bottom: 0.5rem; border-bottom: 1px solid var(--glass-border);\">\r\n                    Mapeamento de Colunas (De-Para)\r\n                </h3>\r\n                <p style=\"font-size: 0.85rem; color: var(--text-dim); margin-bottom: 1.5rem;\">\r\n                    Selecione qual coluna da sua planilha corresponde a cada campo esperado pelo sistema de análise. Campos marcados com * são obrigatórios para a geração dos relatórios e gráficos.\r\n                </p>\r\n\r\n                <div class=\"form-row\" style=\"grid-template-columns: repeat(auto-fill, minmax(280px, 1fr)); row-gap: 1.25rem; column-gap: 1.5rem; margin-bottom: 2rem; display: grid;\" id=\"mappingFormFields\">\r\n                    <!-- Campos dinâmicos inseridos via JS -->\r\n                </div>\r\n\r\n                <h3 style=\"font-size: 1.05rem; font-weight: 700; margin: 2rem 0 1rem 0; padding-bottom: 0.5rem; border-bottom: 1px solid var(--glass-border);\">\r\n                    Prévia dos Dados (Primeiras Linhas)\r\n                </h3>\r\n                <div class=\"table-wrap\" style=\"margin-bottom: 2.5rem; max-height: 250px; overflow-y: auto; border: 1px solid var(--glass-border); border-radius: 12px;\">\r\n                    <table style=\"font-size: 0.78rem; width: 100%;\">\r\n                        <thead id=\"previewTableHead\" style=\"position: sticky; top: 0; background: var(--glass-bg); z-index: 10;\"></thead>\r\n                        <tbody id=\"previewTableBody\"></tbody>\r\n                    </table>\r\n                </div>\r\n\r\n                <div class=\"btn-group\" style=\"justify-content: flex-end; width: 100%; display: flex;\">\r\n                    <button class=\"btn\" onclick=\"voltarParaUrl()\" style=\"margin-right: 0.5rem;\">Voltar</button>\r\n                    <button class=\"btn btn-primary\" onclick=\"confirmarImportacao()\">Confirmar e Importar no Banco</button>\r\n                </div>\r\n            </div>\r\n\r\n            <!-- Etapa 3: Sucesso -->\r\n            <div id=\"import-step-success\" style=\"display:none; text-align:center; padding: 3rem 1rem;\">\r\n                <div style=\"width: 60px; height: 60px; border-radius: 50%; background: rgba(16,185,129,.15); color: var(--success); display: flex; align-items: center; justify-content: center; margin: 0 auto 1.5rem auto;\">\r\n                    <svg width=\"32\" height=\"32\" viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"2.5\"><polyline points=\"20 6 9 17 4 12\"/></svg>\r\n                </div>\r\n                <h2 style=\"font-size: 1.3rem; font-weight: 700; margin-bottom: 0.5rem;\">Importação Concluída!</h2>\r\n                <p id=\"importSuccessMessage\" style=\"color: var(--text-dim); font-size: 0.88rem; margin-bottom: 2rem;\">Os dados foram importados com sucesso para o banco de dados.</p>\r\n                <button class=\"btn btn-primary\" onclick=\"irParaDashboard()\">Ir para o Dashboard</button>\r\n            </div>\r\n        </div>\r\n    </div>\r\n\r\n    <!-- ══ VIEW: ADMIN ══ -->\r\n    <div id=\"view-admin\" class=\"view\" style=\"display:none\">\r\n        <div class=\"block\">\r\n            <div class=\"block-header\">\r\n                <div><div class=\"block-title\">Controle de Acesso</div><div class=\"block-sub\" id=\"adminCount\">Gerenciamento de usuários do sistema</div></div>\r\n                <button class=\"btn btn-primary\" onclick=\"abrirModal('modalNovoUsuario')\">+ Novo Usuário</button>\r\n            </div>\r\n            <div class=\"table-wrap\">\r\n                <table>\r\n                    <thead><tr><th>Nome</th><th>Matrícula</th><th>Perfil</th><th>Status</th><th>Ações</th></tr></thead>\r\n                    <tbody id=\"adminBody\"></tbody>\r\n                </table>\r\n            </div>\r\n        </div>\r\n    </div>\r\n</main>\r\n\r\n<!-- ════════════════ MODAIS ════════════════ -->\r\n\r\n<!-- Modal: Novo Aluno -->\r\n<div class=\"modal-bg\" id=\"modalNovoAluno\">\r\n    <div class=\"modal-box\">\r\n        <div class=\"modal-title\">Cadastrar Novo Aluno</div>\r\n        <div class=\"form-group\"><label>Nome completo *</label><input type=\"text\" id=\"aNome\" class=\"form-control\" placeholder=\"Ex: João Silva\"></div>\r\n        <div class=\"form-row\">\r\n            <div class=\"form-group\"><label>Matrícula *</label><input type=\"text\" id=\"aMatricula\" class=\"form-control\" placeholder=\"Ex: 2024010\"></div>\r\n            <div class=\"form-group\"><label>Período *</label><input type=\"number\" id=\"aPeriodo\" class=\"form-control\" min=\"1\" max=\"10\" value=\"2\"></div>\r\n        </div>\r\n        <div class=\"form-group\"><label>Curso *</label><input type=\"text\" id=\"aCurso\" class=\"form-control\" placeholder=\"Ex: IA, Sistemas\"></div>\r\n        <div class=\"form-group\"><label>E-mail</label><input type=\"email\" id=\"aEmail\" class=\"form-control\" placeholder=\"aluno@uni.edu\"></div>\r\n        <div class=\"modal-footer\">\r\n            <button class=\"btn\" onclick=\"fecharModal('modalNovoAluno')\">Cancelar</button>\r\n            <button class=\"btn btn-primary\" onclick=\"cadastrarAluno()\">Cadastrar</button>\r\n        </div>\r\n    </div>\r\n</div>\r\n\r\n<!-- Modal: Registrar Nota -->\r\n<div class=\"modal-bg\" id=\"modalNota\">\r\n    <div class=\"modal-box\">\r\n        <div class=\"modal-title\">Registrar Nota</div>\r\n        <div style=\"color:var(--text-dim);font-size:.875rem;margin-bottom:1.25rem\" id=\"notaAlunoNome\"></div>\r\n        <input type=\"hidden\" id=\"notaAlunoId\">\r\n        <div class=\"form-group\"><label>Disciplina *</label><input type=\"text\" id=\"notaDisciplina\" class=\"form-control\" placeholder=\"Ex: Álgebra Linear\"></div>\r\n        <div class=\"form-row\">\r\n            <div class=\"form-group\"><label>Nota * (0–10)</label><input type=\"number\" id=\"notaValor\" class=\"form-control\" min=\"0\" max=\"10\" step=\"0.1\" placeholder=\"7.5\"></div>\r\n            <div class=\"form-group\"><label>Período *</label><input type=\"number\" id=\"notaPeriodo\" class=\"form-control\" min=\"1\" max=\"10\" value=\"2\"></div>\r\n        </div>\r\n        <div class=\"modal-footer\">\r\n            <button class=\"btn\" onclick=\"fecharModal('modalNota')\">Cancelar</button>\r\n            <button class=\"btn btn-primary\" onclick=\"registrarNota()\">Registrar</button>\r\n        </div>\r\n    </div>\r\n</div>\r\n\r\n<!-- Modal: Registrar Frequência -->\r\n<div class=\"modal-bg\" id=\"modalFreq\">\r\n    <div class=\"modal-box\">\r\n        <div class=\"modal-title\">Registrar Frequência</div>\r\n        <div style=\"color:var(--text-dim);font-size:.875rem;margin-bottom:1.25rem\" id=\"freqAlunoNome\"></div>\r\n        <input type=\"hidden\" id=\"freqAlunoId\">\r\n        <div class=\"form-group\"><label>Disciplina *</label><input type=\"text\" id=\"freqDisciplina\" class=\"form-control\" placeholder=\"Ex: POO\"></div>\r\n        <div class=\"form-row\">\r\n            <div class=\"form-group\"><label>Frequência * (0–100%)</label><input type=\"number\" id=\"freqValor\" class=\"form-control\" min=\"0\" max=\"100\" step=\"0.1\" placeholder=\"85\"></div>\r\n            <div class=\"form-group\"><label>Período *</label><input type=\"number\" id=\"freqPeriodo\" class=\"form-control\" min=\"1\" max=\"10\" value=\"2\"></div>\r\n        </div>\r\n        <div class=\"modal-footer\">\r\n            <button class=\"btn\" onclick=\"fecharModal('modalFreq')\">Cancelar</button>\r\n            <button class=\"btn btn-primary\" onclick=\"registrarFrequencia()\">Registrar</button>\r\n        </div>\r\n    </div>\r\n</div>\r\n\r\n<!-- Modal: Novo Usuário -->\r\n<div class=\"modal-bg\" id=\"modalNovoUsuario\">\r\n    <div class=\"modal-box\">\r\n        <div class=\"modal-title\">Cadastrar Usuário</div>\r\n        <div class=\"form-group\"><label>Nome completo *</label><input type=\"text\" id=\"uNome\" class=\"form-control\" placeholder=\"Ex: João Silva\"></div>\r\n        <div class=\"form-row\">\r\n            <div class=\"form-group\"><label>Matrícula *</label><input type=\"text\" id=\"uMatricula\" class=\"form-control\" placeholder=\"Ex: 2024010\"></div>\r\n            <div class=\"form-group\"><label>Perfil *</label>\r\n                <select id=\"uPerfil\" class=\"form-control\">\r\n                    <option value=\"visualizador\">Visualizador</option>\r\n                    <option value=\"professor\">Professor</option>\r\n                    <option value=\"coordenador\">Coordenador</option>\r\n                    <option value=\"admin\">Admin</option>\r\n                </select>\r\n            </div>\r\n        </div>\r\n        <div class=\"form-group\"><label>Senha *</label><input type=\"password\" id=\"uSenha\" class=\"form-control\" placeholder=\"Mínimo 4 caracteres\"></div>\r\n        <div class=\"modal-footer\">\r\n            <button class=\"btn\" onclick=\"fecharModal('modalNovoUsuario')\">Cancelar</button>\r\n            <button class=\"btn btn-primary\" onclick=\"criarUsuario()\">Cadastrar</button>\r\n        </div>\r\n    </div>\r\n</div>\r\n\r\n<!-- Modal: Sync Lyceum -->\r\n<div class=\"modal-bg\" id=\"syncModal\">\r\n    <div class=\"modal-box\">\r\n        <div class=\"modal-title\">Conectar ao Lyceum</div>\r\n        <p style=\"color:var(--text-dim);margin-bottom:1.5rem;font-size:.875rem\">Nexus irá importar notas e frequência automaticamente.</p>\r\n        <div class=\"form-group\" style=\"margin-bottom:1rem\">\r\n            <label style=\"color:var(--text-dim);font-size:.78rem\">Portal</label>\r\n            <div style=\"font-size:.85rem;color:#64748b;background:#F8FAFC;border:1px solid var(--glass-border);border-radius:10px;padding:.6rem .9rem;word-break:break-all\">https://portal.unievangelica.edu.br/aluno/#/login</div>\r\n        </div>\r\n        <input type=\"hidden\" id=\"lyceumUrl\" value=\"https://portal.unievangelica.edu.br/aluno/#/login\">\r\n        <div class=\"form-group\"><label>Usuário / CPF</label><input type=\"text\" id=\"lyceumUser\" class=\"form-control\"></div>\r\n        <div class=\"form-group\"><label>Senha</label><input type=\"password\" id=\"lyceumPass\" class=\"form-control\"></div>\r\n        <div class=\"modal-footer\">\r\n            <button class=\"btn\" onclick=\"fecharModal('syncModal')\">Cancelar</button>\r\n            <button class=\"btn btn-primary\" id=\"btnDoSync\">Sincronizar</button>\r\n        </div>\r\n    </div>\r\n</div>\r\n\r\n<script>\r\n/* ══════════════════════════════════\r\n   TEMA CLARO / ESCURO\r\n══════════════════════════════════ */\r\nfunction cc() {\r\n    const dark = document.documentElement.getAttribute('data-theme') === 'dark';\r\n    return {\r\n        grid: dark ? 'rgba(255,255,255,.04)' : 'rgba(0,0,0,.06)',\r\n        tick: dark ? '#94a3b8' : '#64748b',\r\n    };\r\n}\r\n\r\nlet _currentView = 'dashboard';\r\n\r\nfunction applyTheme(dark) {\r\n    document.documentElement.setAttribute('data-theme', dark ? 'dark' : 'light');\r\n    localStorage.setItem('nexus_theme', dark ? 'dark' : 'light');\r\n    const icon = document.getElementById('themeIcon');\r\n    if (dark) {\r\n        icon.innerHTML = '<circle cx=\"12\" cy=\"12\" r=\"5\"/><line x1=\"12\" y1=\"1\" x2=\"12\" y2=\"3\"/><line x1=\"12\" y1=\"21\" x2=\"12\" y2=\"23\"/><line x1=\"4.22\" y1=\"4.22\" x2=\"5.64\" y2=\"5.64\"/><line x1=\"18.36\" y1=\"18.36\" x2=\"19.78\" y2=\"19.78\"/><line x1=\"1\" y1=\"12\" x2=\"3\" y2=\"12\"/><line x1=\"21\" y1=\"12\" x2=\"23\" y2=\"12\"/><line x1=\"4.22\" y1=\"19.78\" x2=\"5.64\" y2=\"18.36\"/><line x1=\"18.36\" y1=\"5.64\" x2=\"19.78\" y2=\"4.22\"/>';\r\n    } else {\r\n        icon.innerHTML = '<path d=\"M21 12.79A9 9 0 1 1 11.21 3 7 7 0 0 0 21 12.79z\"/>';\r\n    }\r\n    if (Object.keys(charts).length > 0) {\r\n        if (_currentView === 'dashboard') carregarDashboard();\r\n        else if (_currentView === 'alertas') carregarAlertas();\r\n    }\r\n}\r\n\r\n/* ══════════════════════════════════\r\n   MOCK DE DADOS (modo teste)\r\n══════════════════════════════════ */\r\nconst MOCK_MODE = false;\r\n\r\nconst MOCK_TURMAS = [\r\n    { id:'t1', nome:'ADS – 1º Período',   curso:'Análise e Des. de Sistemas', periodo:1, turno:'Noturno'    },\r\n    { id:'t2', nome:'ADS – 2º Período',   curso:'Análise e Des. de Sistemas', periodo:2, turno:'Noturno'    },\r\n    { id:'t3', nome:'IA – 2º Período',    curso:'Inteligência Artificial',     periodo:2, turno:'Matutino'   },\r\n    { id:'t4', nome:'Redes – 3º Período', curso:'Redes de Computadores',       periodo:3, turno:'Vespertino' },\r\n    { id:'t5', nome:'IA – 4º Período',    curso:'Inteligência Artificial',     periodo:4, turno:'Matutino'   },\r\n];\r\n\r\nconst MOCK_ALUNOS = [\r\n    // ADS 1º Período\r\n    { id:'a1',  nome:'Ana Clara Souza',     matricula:'2024001', curso:'Análise e Des. de Sistemas', periodo:1, turmaId:'t1', email:'ana@uni.edu' },\r\n    { id:'a2',  nome:'Bruno Mendes',         matricula:'2024002', curso:'Análise e Des. de Sistemas', periodo:1, turmaId:'t1', email:'bruno@uni.edu' },\r\n    { id:'a3',  nome:'Carla Figueiredo',     matricula:'2024003', curso:'Análise e Des. de Sistemas', periodo:1, turmaId:'t1', email:'carla@uni.edu' },\r\n    { id:'a4',  nome:'Diego Alves',          matricula:'2024004', curso:'Análise e Des. de Sistemas', periodo:1, turmaId:'t1', email:'diego@uni.edu' },\r\n    { id:'a5',  nome:'Eduarda Pires',        matricula:'2024005', curso:'Análise e Des. de Sistemas', periodo:1, turmaId:'t1', email:'edu@uni.edu' },\r\n    { id:'a6',  nome:'Felipe Costa',         matricula:'2024006', curso:'Análise e Des. de Sistemas', periodo:1, turmaId:'t1', email:'felipe@uni.edu' },\r\n    { id:'a7',  nome:'Gabriela Nunes',       matricula:'2024007', curso:'Análise e Des. de Sistemas', periodo:1, turmaId:'t1', email:'gabi@uni.edu' },\r\n    // ADS 2º Período\r\n    { id:'a8',  nome:'Henrique Barbosa',     matricula:'2024008', curso:'Análise e Des. de Sistemas', periodo:2, turmaId:'t2', email:'henrique@uni.edu' },\r\n    { id:'a9',  nome:'Isabela Rocha',        matricula:'2024009', curso:'Análise e Des. de Sistemas', periodo:2, turmaId:'t2', email:'isa@uni.edu' },\r\n    { id:'a10', nome:'João Pedro Lima',      matricula:'2024010', curso:'Análise e Des. de Sistemas', periodo:2, turmaId:'t2', email:'jp@uni.edu' },\r\n    { id:'a11', nome:'Karina Tavares',       matricula:'2024011', curso:'Análise e Des. de Sistemas', periodo:2, turmaId:'t2', email:'karina@uni.edu' },\r\n    { id:'a12', nome:'Lucas Ferreira',       matricula:'2024012', curso:'Análise e Des. de Sistemas', periodo:2, turmaId:'t2', email:'lucas@uni.edu' },\r\n    { id:'a13', nome:'Mariana Oliveira',     matricula:'2024013', curso:'Análise e Des. de Sistemas', periodo:2, turmaId:'t2', email:'mari@uni.edu' },\r\n    // IA 2º Período\r\n    { id:'a14', nome:'Nathan Correia',       matricula:'2024014', curso:'Inteligência Artificial', periodo:2, turmaId:'t3', email:'nathan@uni.edu' },\r\n    { id:'a15', nome:'Olivia Santana',       matricula:'2024015', curso:'Inteligência Artificial', periodo:2, turmaId:'t3', email:'olivia@uni.edu' },\r\n    { id:'a16', nome:'Pedro Henrique Souza', matricula:'2024016', curso:'Inteligência Artificial', periodo:2, turmaId:'t3', email:'pedro@uni.edu' },\r\n    { id:'a17', nome:'Queila Monteiro',      matricula:'2024017', curso:'Inteligência Artificial', periodo:2, turmaId:'t3', email:'queila@uni.edu' },\r\n    { id:'a18', nome:'Rafael Gomes',         matricula:'2024018', curso:'Inteligência Artificial', periodo:2, turmaId:'t3', email:'rafael@uni.edu' },\r\n    { id:'a19', nome:'Sara Lopes',           matricula:'2024019', curso:'Inteligência Artificial', periodo:2, turmaId:'t3', email:'sara@uni.edu' },\r\n    { id:'a20', nome:'Thiago Azevedo',       matricula:'2024020', curso:'Inteligência Artificial', periodo:2, turmaId:'t3', email:'thiago@uni.edu' },\r\n    { id:'a21', nome:'Úrsula Machado',       matricula:'2024021', curso:'Inteligência Artificial', periodo:2, turmaId:'t3', email:'ursula@uni.edu' },\r\n    // Redes 3º Período\r\n    { id:'a22', nome:'Vitor Carvalho',       matricula:'2024022', curso:'Redes de Computadores', periodo:3, turmaId:'t4', email:'vitor@uni.edu' },\r\n    { id:'a23', nome:'Wanderley Silva',      matricula:'2024023', curso:'Redes de Computadores', periodo:3, turmaId:'t4', email:'wanderley@uni.edu' },\r\n    { id:'a24', nome:'Ximena Brandão',       matricula:'2024024', curso:'Redes de Computadores', periodo:3, turmaId:'t4', email:'ximena@uni.edu' },\r\n    { id:'a25', nome:'Yasmin Freitas',       matricula:'2024025', curso:'Redes de Computadores', periodo:3, turmaId:'t4', email:'yasmin@uni.edu' },\r\n    { id:'a26', nome:'Zara Nascimento',      matricula:'2024026', curso:'Redes de Computadores', periodo:3, turmaId:'t4', email:'zara@uni.edu' },\r\n    { id:'a27', nome:'Artur Medeiros',       matricula:'2024027', curso:'Redes de Computadores', periodo:3, turmaId:'t4', email:'artur@uni.edu' },\r\n    // IA 4º Período\r\n    { id:'a28', nome:'Beatriz Castro',       matricula:'2024028', curso:'Inteligência Artificial', periodo:4, turmaId:'t5', email:'beatriz@uni.edu' },\r\n    { id:'a29', nome:'Carlos Eduardo Melo',  matricula:'2024029', curso:'Inteligência Artificial', periodo:4, turmaId:'t5', email:'carlos@uni.edu' },\r\n    { id:'a30', nome:'Daniela Ramos',        matricula:'2024030', curso:'Inteligência Artificial', periodo:4, turmaId:'t5', email:'daniela@uni.edu' },\r\n    { id:'a31', nome:'Eduardo Pinto',        matricula:'2024031', curso:'Inteligência Artificial', periodo:4, turmaId:'t5', email:'eduardo@uni.edu' },\r\n    { id:'a32', nome:'Fernanda Dias',        matricula:'2024032', curso:'Inteligência Artificial', periodo:4, turmaId:'t5', email:'fernanda@uni.edu' },\r\n    { id:'a33', nome:'Gustavo Maia',         matricula:'2024033', curso:'Inteligência Artificial', periodo:4, turmaId:'t5', email:'gustavo@uni.edu' },\r\n];\r\n\r\nconst MOCK_DISCIPLINAS = ['Álgebra Linear', 'Cálculo I', 'Programação', 'Estatística', 'Banco de Dados'];\r\nconst MOCK_DISCIPLINAS_POR_TURMA = {\r\n    t1: ['Algoritmos', 'Lógica de Prog.', 'Inglês Técnico', 'Mat. Discreta', 'Cálculo I'],\r\n    t2: ['Estrut. de Dados', 'Banco de Dados I', 'Eng. de Software', 'POO', 'Cálculo II'],\r\n    t3: ['Machine Learning', 'Álgebra Linear',  'Programação',      'Estatística', 'Redes Neurais'],\r\n    t4: ['Protocolos TCP/IP','Segurança de Redes','Infra. de TI',   'Sistemas Op.', 'Criptografia'],\r\n    t5: ['Deep Learning',   'Visão Computacional','NLP',            'Ética em IA',  'TCC I'],\r\n};\r\n\r\nfunction rnd(min, max, dec = 2) { return parseFloat((Math.random() * (max - min) + min).toFixed(dec)); }\r\n\r\nconst _mockRelCache = {};\r\nconst _mockDiscCache = {};\r\n\r\nfunction _alunoRelatorio(a) {\r\n    if (_mockRelCache[a.id]) return _mockRelCache[a.id];\r\n    const media = rnd(3.5, 9.8);\r\n    const freq  = rnd(62, 99, 1);\r\n    const iaa   = parseFloat((media * 0.7 + (freq / 10) * 0.3).toFixed(2));\r\n    const irp   = parseFloat(Math.min(100, Math.max(0, (10 - media) * 5 + Math.max(0, 75 - freq) * 1.5)).toFixed(1));\r\n    const risco = media < 4.5 || freq < 70 ? (media < 3 ? 'critico' : 'alto') : media < 6.5 ? 'medio' : 'baixo';\r\n    _mockRelCache[a.id] = { aluno_id:a.id, nome:a.nome, matricula:a.matricula, media_geral:media, frequencia_media:freq, iaa, irp, risco, zscore:rnd(-2.5,2.5), percentil:rnd(5,98,1) };\r\n    return _mockRelCache[a.id];\r\n}\r\n\r\nfunction _turmaDisciplinas(turmaId) {\r\n    if (_mockDiscCache[turmaId]) return _mockDiscCache[turmaId];\r\n    const discs = MOCK_DISCIPLINAS_POR_TURMA[turmaId] || MOCK_DISCIPLINAS;\r\n    _mockDiscCache[turmaId] = discs.map(d => ({\r\n        disciplina:d, media:rnd(4.5,8.8), mediana:rnd(4,8.5),\r\n        desvio_padrao:rnd(0.5,1.8), nota_min:rnd(2,4.5), nota_max:rnd(7.5,10),\r\n        total_alunos: MOCK_ALUNOS.filter(a => a.turmaId===turmaId).length, taxa_aprovacao:rnd(55,95,1),\r\n    }));\r\n    return _mockDiscCache[turmaId];\r\n}\r\n\r\nfunction _turmaResumo(t) {\r\n    const alunos = MOCK_ALUNOS.filter(a => a.turmaId === t.id);\r\n    const rels   = alunos.map(_alunoRelatorio);\r\n    const medias = rels.map(r => r.media_geral);\r\n    const freqs  = rels.map(r => r.frequencia_media);\r\n    const avg = arr => arr.length ? arr.reduce((s,v)=>s+v,0)/arr.length : 0;\r\n    return {\r\n        ...t,\r\n        total_alunos: alunos.length,\r\n        media_turma:  parseFloat(avg(medias).toFixed(2)),\r\n        freq_media:   parseFloat(avg(freqs).toFixed(1)),\r\n        alunos_em_alerta: rels.filter(r=>r.risco==='alto'||r.risco==='critico').length,\r\n        taxa_aprovacao:   parseFloat(((rels.filter(r=>r.media_geral>=5).length/rels.length)*100).toFixed(1)),\r\n        distribuicao_risco:{\r\n            baixo:   rels.filter(r=>r.risco==='baixo').length,\r\n            medio:   rels.filter(r=>r.risco==='medio').length,\r\n            alto:    rels.filter(r=>r.risco==='alto').length,\r\n            critico: rels.filter(r=>r.risco==='critico').length,\r\n        },\r\n    };\r\n}\r\n\r\nfunction mockFetch(url) {\r\n    // Turma drill-down\r\n    const turmaRelMatch = url.match(/\\/turmas\\/(t\\d+)\\/relatorio/);\r\n    if (turmaRelMatch) {\r\n        const turmaId = turmaRelMatch[1];\r\n        const turma   = MOCK_TURMAS.find(t => t.id === turmaId);\r\n        const alunos  = MOCK_ALUNOS.filter(a => a.turmaId === turmaId);\r\n        const rels    = alunos.map(_alunoRelatorio);\r\n        const medias  = rels.map(r => r.media_geral);\r\n        const freqs   = rels.map(r => r.frequencia_media);\r\n        const avg = arr => arr.length ? arr.reduce((s,v)=>s+v,0)/arr.length : 0;\r\n        return {\r\n            turma,\r\n            total: rels.length,\r\n            alunos: rels,\r\n            stats: {\r\n                media:          parseFloat(avg(medias).toFixed(2)),\r\n                freq:           parseFloat(avg(freqs).toFixed(1)),\r\n                em_alerta:      rels.filter(r=>r.risco==='alto'||r.risco==='critico').length,\r\n                criticos:       rels.filter(r=>r.risco==='critico').length,\r\n                taxa_aprovacao: parseFloat(((rels.filter(r=>r.media_geral>=5).length/rels.length)*100).toFixed(1)),\r\n            },\r\n            pontos_dispersao: rels.map(r=>({ nome:r.nome, frequencia:r.frequencia_media, media:r.media_geral })),\r\n            disciplinas: _turmaDisciplinas(turmaId),\r\n        };\r\n    }\r\n    // Lista de turmas\r\n    if (url === '/turmas') {\r\n        return MOCK_TURMAS.map(_turmaResumo);\r\n    }\r\n    if (url.includes('/relatorios/turma') && !url.includes('exportar')) {\r\n        const alunos = MOCK_ALUNOS.map(_alunoRelatorio);\r\n        return { periodo:2, total:alunos.length, alunos };\r\n    }\r\n    if (url.includes('/relatorios/estatisticas')) {\r\n        return {\r\n            periodo:2,\r\n            estatisticas_turma:{\r\n                media_institucional:rnd(5.5,8.2), mediana_institucional:rnd(5,8),\r\n                desvio_padrao_turma:rnd(0.8,2.2), coeficiente_variacao:rnd(10,32,1),\r\n                frequencia_media_turma:rnd(74,94,1), total_alunos:MOCK_ALUNOS.length, taxa_aprovacao:rnd(55,92,1),\r\n            },\r\n            correlacao_freq_nota:rnd(0.45,0.88),\r\n            interpretacao_correlacao:'Correlação positiva forte entre frequência e nota (r≈0.72)',\r\n            distribuicao_medias:{'0–2':1,'2–4':1,'4–6':2,'6–8':3,'8–10':1},\r\n            pontos_dispersao:MOCK_ALUNOS.map(a=>({ nome:a.nome, frequencia:rnd(62,99,1), media:rnd(3.5,9.8) })),\r\n        };\r\n    }\r\n    if (url.includes('/relatorios/disciplinas')) {\r\n        return {\r\n            periodo:2,\r\n            disciplinas: MOCK_DISCIPLINAS.map(d => ({\r\n                disciplina:d, media:rnd(4.5,8.8), mediana:rnd(4,8.5),\r\n                desvio_padrao:rnd(0.5,1.8), nota_min:rnd(2,4.5), nota_max:rnd(7.5,10),\r\n                total_alunos:MOCK_ALUNOS.length, taxa_aprovacao:rnd(55,95,1),\r\n            })),\r\n        };\r\n    }\r\n    if (url.startsWith('/alunos') && !url.includes('/notas') && !url.includes('/frequencias')) {\r\n        return MOCK_ALUNOS;\r\n    }\r\n    if (url.includes('/alertas')) {\r\n        const alertas = [\r\n            { nivel:'critico', aluno_id:'a4',  aluno_nome:'Diego Alves',      tipo:'frequencia',     mensagem:'Frequência crítica: 68.3% — abaixo do mínimo de 75%', acao:'Contato urgente e plano de reposição' },\r\n            { nivel:'critico', aluno_id:'a23', aluno_nome:'Wanderley Silva',   tipo:'desempenho',     mensagem:'Média abaixo do mínimo: 4.2 — risco de reprovação', acao:'Tutoria individual urgente' },\r\n            { nivel:'alto',    aluno_id:'a6',  aluno_nome:'Felipe Costa',      tipo:'desempenho',     mensagem:'Média em zona de risco: 5.8', acao:'Incentivar participação e verificar dificuldades' },\r\n            { nivel:'alto',    aluno_id:'a17', aluno_nome:'Queila Monteiro',   tipo:'frequencia',     mensagem:'Frequência em atenção: 77.2% — próxima do limite mínimo', acao:'Monitorar assiduidade e conversar com o aluno' },\r\n            { nivel:'medio',   aluno_id:'a2',  aluno_nome:'Bruno Mendes',      tipo:'inconsistencia', mensagem:'Desempenho irregular entre disciplinas (CV: 38.1%)', acao:'Identificar disciplinas críticas e direcionar suporte' },\r\n            { nivel:'medio',   aluno_id:'a31', aluno_nome:'Eduardo Pinto',     tipo:'comparativo',    mensagem:'Desempenho 1.8 desvios abaixo da média da turma', acao:'Acompanhamento pedagógico especializado' },\r\n        ];\r\n        return { periodo:2, total:alertas.length, alertas };\r\n    }\r\n    if (url.includes('/admin/usuarios')) {\r\n        return [\r\n            { id:'u1', nome:'Administrador', matricula:'admin',  perfil:'admin',       ativo:true },\r\n            { id:'u2', nome:'Prof. Marcos',  matricula:'prof01', perfil:'professor',   ativo:true },\r\n            { id:'u3', nome:'Coord. Lúcia',  matricula:'coord1', perfil:'coordenador', ativo:true },\r\n        ];\r\n    }\r\n    return null;\r\n}\r\n\r\nif (MOCK_MODE) {\r\n    localStorage.setItem('nexus_token',  'mock-token-teste');\r\n    localStorage.setItem('nexus_perfil', 'admin');\r\n    localStorage.setItem('nexus_nome',   'Administrador');\r\n}\r\n\r\n/* ══════════════════════════════════\r\n   SIDEBAR TOGGLE\r\n══════════════════════════════════ */\r\nfunction toggleSidebar() {\r\n    document.getElementById('sidebar').classList.toggle('open');\r\n    document.getElementById('sidebarBackdrop').classList.toggle('open');\r\n}\r\nfunction closeSidebar() {\r\n    document.getElementById('sidebar').classList.remove('open');\r\n    document.getElementById('sidebarBackdrop').classList.remove('open');\r\n}\r\n\r\n/* ══════════════════════════════════\r\n   UTILITÁRIOS\r\n══════════════════════════════════ */\r\nlet charts = {};\r\n\r\nfunction destroyChart(id) { if (charts[id]) { charts[id].destroy(); delete charts[id]; } }\r\nfunction token() { return localStorage.getItem('nexus_token') || ''; }\r\n\r\nasync function apiFetch(url, opts = {}) {\r\n    if (MOCK_MODE) {\r\n        await new Promise(r => setTimeout(r, 80));\r\n        return mockFetch(url);\r\n    }\r\n    const res = await fetch(url, {\r\n        ...opts,\r\n        headers: { 'Content-Type': 'application/json', Authorization: `Bearer ${token()}`, ...(opts.headers || {}) }\r\n    });\r\n    if (res.status === 401) { window.location.href = '/login'; return null; }\r\n    try { return await res.json(); } catch { return null; }\r\n}\r\n\r\nfunction riskClass(n) { return {baixo:'badge-baixo',medio:'badge-medio',alto:'badge-alto',critico:'badge-critico'}[n] || 'badge-medio'; }\r\nfunction riskLabel(n) { return {baixo:'Baixo',medio:'Médio',alto:'Alto',critico:'Crítico'}[n] || n; }\r\n\r\nfunction abrirModal(id) { document.getElementById(id).classList.add('open'); }\r\nfunction fecharModal(id) { document.getElementById(id).classList.remove('open'); }\r\n\r\n// Fecha modal ao clicar no fundo\r\ndocument.querySelectorAll('.modal-bg').forEach(m => {\r\n    m.addEventListener('click', e => { if (e.target === m) m.classList.remove('open'); });\r\n});\r\n\r\n/* ══════════════════════════════════\r\n   NAVEGAÇÃO\r\n══════════════════════════════════ */\r\nconst VIEW_META = {\r\n    dashboard:   { title: 'Painel Analítico',       sub: '' },\r\n    alunos:      { title: 'Gestão de Alunos',        sub: 'Cadastro e monitoramento de estudantes' },\r\n    alertas:     { title: 'Alertas Inteligentes',    sub: 'Padrões de risco detectados automaticamente' },\r\n    importar:    { title: 'Importar de Planilha Google', sub: 'Importe dados do Google Sheets como banco de dados principal' },\r\n    admin:       { title: 'Controle de Acesso',      sub: 'Gerenciamento de usuários e permissões do sistema' },\r\n};\r\n\r\nfunction showView(viewId) {\r\n    _currentView = viewId;\r\n    closeSidebar();\r\n    // Esconde todas as views\r\n    document.querySelectorAll('.view').forEach(v => v.style.display = 'none');\r\n    document.getElementById('view-' + viewId).style.display = '';\r\n\r\n    // Atualiza active na sidebar\r\n    document.querySelectorAll('.nav-link[data-view]').forEach(l => l.classList.remove('active'));\r\n    const link = document.querySelector(`.nav-link[data-view=\"${viewId}\"]`);\r\n    if (link) link.classList.add('active');\r\n\r\n    // Atualiza título\r\n    const meta = VIEW_META[viewId] || {};\r\n    document.getElementById('pageTitle').textContent = meta.title || '';\r\n    document.getElementById('pageSubtitle').textContent = meta.sub || '';\r\n\r\n    // Atualiza botão de ação da topbar\r\n    const actions = document.getElementById('topBarActions');\r\n    if (viewId === 'dashboard') {\r\n        actions.innerHTML = '';\r\n    } else if (viewId === 'alunos') {\r\n        actions.innerHTML = `<button class=\"btn btn-primary\" onclick=\"abrirModal('modalNovoAluno')\">+ Novo Aluno</button>`;\r\n    } else {\r\n        actions.innerHTML = '';\r\n    }\r\n\r\n    // Carrega dados da view\r\n    if (viewId === 'dashboard') carregarDashboard();\r\n    else if (viewId === 'alunos') carregarAlunos();\r\n    else if (viewId === 'alertas') carregarAlertas();\r\n    else if (viewId === 'importar') inicializarImportador();\r\n    else if (viewId === 'admin') carregarUsuarios();\r\n}\r\n\r\n/* ══════════════════════════════════\r\n   VIEW: DASHBOARD — VISÃO DE TURMAS\r\n══════════════════════════════════ */\r\nlet _turmasData = [];\r\n\r\nasync function carregarDashboard() {\r\n    const data = await apiFetch('/turmas');\r\n    if (!data) return;\r\n    _turmasData = data;\r\n    renderKPIsTurmas(data);\r\n    renderTabelaTurmas(data);\r\n    renderChartMediaTurmas(data);\r\n    renderChartRiscoGeral(data);\r\n    renderChartAprovacaoTurmas(data);\r\n    renderChartFreqTurmas(data);\r\n}\r\n\r\nfunction renderKPIsTurmas(turmas) {\r\n    const totalAlunos = turmas.reduce((s,t)=>s+t.total_alunos, 0);\r\n    const avg = arr => arr.reduce((s,v)=>s+v,0)/arr.length;\r\n    const mediaInst    = avg(turmas.map(t=>t.media_turma)).toFixed(2);\r\n    const freqMedia    = avg(turmas.map(t=>t.freq_media)).toFixed(1);\r\n    const emAlerta     = turmas.reduce((s,t)=>s+t.alunos_em_alerta, 0);\r\n    const criticos     = turmas.reduce((s,t)=>s+t.distribuicao_risco.critico, 0);\r\n    const taxaGeral    = avg(turmas.map(t=>t.taxa_aprovacao)).toFixed(1);\r\n\r\n    document.getElementById('kTotalLabel').textContent   = 'Total de Turmas';\r\n    document.getElementById('kTotal').textContent        = turmas.length;\r\n    document.getElementById('kMediaLabel').textContent   = 'Média Institucional';\r\n    document.getElementById('kMedia').textContent        = mediaInst;\r\n    document.getElementById('kFreqLabel').textContent    = 'Freq. Média Geral';\r\n    document.getElementById('kFreq').textContent         = freqMedia + '%';\r\n    document.getElementById('kFreqSub').textContent      = `total de alunos: ${totalAlunos}`;\r\n    document.getElementById('kRiscoLabel').textContent   = 'Alunos em Alerta';\r\n    document.getElementById('kRisco').textContent        = emAlerta;\r\n    document.getElementById('kCritico').textContent      = `críticos: ${criticos}`;\r\n    document.getElementById('kAprovacaoLabel').textContent = 'Aprovação Geral';\r\n    document.getElementById('kAprovacao').textContent    = taxaGeral + '%';\r\n}\r\n\r\nfunction renderTabelaTurmas(turmas) {\r\n    document.getElementById('tabelaTurmasBody').innerHTML = turmas.map(t => `\r\n        <tr class=\"turma-row\" onclick=\"verTurma('${t.id}')\">\r\n            <td><strong>${t.nome}</strong><div style=\"font-size:.7rem;color:var(--text-dim)\">${t.turno}</div></td>\r\n            <td style=\"color:var(--text-dim);font-size:.82rem\">${t.curso}</td>\r\n            <td>${t.total_alunos}</td>\r\n            <td><strong>${t.media_turma.toFixed(2)}</strong></td>\r\n            <td>${t.freq_media.toFixed(1)}%</td>\r\n            <td>${t.taxa_aprovacao.toFixed(0)}%</td>\r\n            <td>\r\n                <div style=\"display:flex;gap:.3rem;flex-wrap:wrap\">\r\n                    <span class=\"badge badge-baixo\">${t.distribuicao_risco.baixo}B</span>\r\n                    <span class=\"badge badge-medio\">${t.distribuicao_risco.medio}M</span>\r\n                    ${t.distribuicao_risco.alto > 0 ? `<span class=\"badge badge-alto\">${t.distribuicao_risco.alto}A</span>` : ''}\r\n                    ${t.distribuicao_risco.critico > 0 ? `<span class=\"badge badge-critico\">${t.distribuicao_risco.critico}C</span>` : ''}\r\n                </div>\r\n            </td>\r\n            <td><button class=\"btn btn-sm btn-primary\" onclick=\"event.stopPropagation();verTurma('${t.id}')\">Ver turma →</button></td>\r\n        </tr>`).join('');\r\n}\r\n\r\nconst TURMA_CORES = ['#6366f1','#34d399','#f59e0b','#38bdf8','#fb7185'];\r\n\r\nfunction renderChartMediaTurmas(turmas) {\r\n    destroyChart('turmasMedia');\r\n    charts.turmasMedia = new Chart(document.getElementById('chartTurmasMedia').getContext('2d'), {\r\n        type:'bar',\r\n        data:{\r\n            labels: turmas.map(t=>t.nome),\r\n            datasets:[{ label:'Média', data:turmas.map(t=>t.media_turma),\r\n                backgroundColor: turmas.map((_,i)=>TURMA_CORES[i%TURMA_CORES.length]+'bb'), borderRadius:8 }]\r\n        },\r\n        options:{\r\n            responsive:true, maintainAspectRatio:false,\r\n            onClick:(evt,els)=>{ if(els.length) verTurma(turmas[els[0].index].id); },\r\n            plugins:{\r\n                legend:{display:false},\r\n                tooltip:{callbacks:{title:c=>[c[0].label], afterLabel:()=>'  Clique para ver alunos'}}\r\n            },\r\n            scales:{\r\n                y:{min:0,max:10,grid:{color:cc().grid},ticks:{color:cc().tick}},\r\n                x:{grid:{display:false},ticks:{color:cc().tick,maxRotation:25,font:{size:11}}}\r\n            }\r\n        }\r\n    });\r\n}\r\n\r\nfunction renderChartRiscoGeral(turmas) {\r\n    destroyChart('riscoGeral');\r\n    const totais = turmas.reduce((acc,t)=>{\r\n        acc.baixo   += t.distribuicao_risco.baixo;\r\n        acc.medio   += t.distribuicao_risco.medio;\r\n        acc.alto    += t.distribuicao_risco.alto;\r\n        acc.critico += t.distribuicao_risco.critico;\r\n        return acc;\r\n    }, {baixo:0,medio:0,alto:0,critico:0});\r\n    charts.riscoGeral = new Chart(document.getElementById('chartRiscoGeral').getContext('2d'), {\r\n        type:'doughnut',\r\n        data:{\r\n            labels:['Baixo','Médio','Alto','Crítico'],\r\n            datasets:[{ data:[totais.baixo,totais.medio,totais.alto,totais.critico],\r\n                backgroundColor:['#34d399','#fbbf24','#fb7185','#f87171'], borderWidth:0, hoverOffset:10 }]\r\n        },\r\n        options:{\r\n            responsive:true, maintainAspectRatio:false, cutout:'70%',\r\n            plugins:{legend:{labels:{color:cc().tick,boxWidth:12,font:{size:11}},position:'bottom'}}\r\n        }\r\n    });\r\n}\r\n\r\nfunction renderChartAprovacaoTurmas(turmas) {\r\n    destroyChart('turmasAprov');\r\n    charts.turmasAprov = new Chart(document.getElementById('chartTurmasAprovacao').getContext('2d'), {\r\n        type:'bar',\r\n        data:{\r\n            labels: turmas.map(t=>t.nome),\r\n            datasets:[{ label:'Aprovação (%)', data:turmas.map(t=>t.taxa_aprovacao),\r\n                backgroundColor:turmas.map(t=>t.taxa_aprovacao>=70?'rgba(52,211,153,.75)':t.taxa_aprovacao>=55?'rgba(251,191,36,.75)':'rgba(251,113,133,.75)'),\r\n                borderRadius:8 }]\r\n        },\r\n        options:{\r\n            responsive:true, maintainAspectRatio:false,\r\n            onClick:(evt,els)=>{ if(els.length) verTurma(turmas[els[0].index].id); },\r\n            plugins:{legend:{display:false}},\r\n            scales:{\r\n                y:{min:0,max:100,grid:{color:cc().grid},ticks:{color:cc().tick,callback:v=>v+'%'}},\r\n                x:{grid:{display:false},ticks:{color:cc().tick,maxRotation:25,font:{size:11}}}\r\n            }\r\n        }\r\n    });\r\n}\r\n\r\nfunction renderChartFreqTurmas(turmas) {\r\n    destroyChart('turmasFreq');\r\n    charts.turmasFreq = new Chart(document.getElementById('chartTurmasFreq').getContext('2d'), {\r\n        type:'bar',\r\n        data:{\r\n            labels: turmas.map(t=>t.nome),\r\n            datasets:[{ label:'Frequência (%)', data:turmas.map(t=>t.freq_media),\r\n                backgroundColor:turmas.map(t=>t.freq_media>=80?'rgba(56,189,248,.75)':t.freq_media>=75?'rgba(251,191,36,.75)':'rgba(251,113,133,.75)'),\r\n                borderRadius:8 }]\r\n        },\r\n        options:{\r\n            responsive:true, maintainAspectRatio:false,\r\n            onClick:(evt,els)=>{ if(els.length) verTurma(turmas[els[0].index].id); },\r\n            plugins:{legend:{display:false}},\r\n            scales:{\r\n                y:{min:60,max:100,grid:{color:cc().grid},ticks:{color:cc().tick,callback:v=>v+'%'}},\r\n                x:{grid:{display:false},ticks:{color:cc().tick,maxRotation:25,font:{size:11}}}\r\n            }\r\n        }\r\n    });\r\n}\r\n\r\n/* ══════════════════════════════════\r\n   DRILL-DOWN DE TURMA\r\n══════════════════════════════════ */\r\nasync function verTurma(turmaId) {\r\n    const data = await apiFetch(`/turmas/${turmaId}/relatorio`);\r\n    if (!data) return;\r\n\r\n    document.getElementById('dashBreadcrumb').style.display    = 'flex';\r\n    document.getElementById('dashTurmaLabel').textContent      = data.turma.nome;\r\n    document.getElementById('dashTurmasPanel').style.display   = 'none';\r\n    document.getElementById('dashAlunosPanel').style.display   = '';\r\n\r\n    renderKPIsTurma(data);\r\n    renderPerformance(data.alunos);\r\n    renderRisco(data.alunos);\r\n    renderScatter(data.pontos_dispersao);\r\n    renderHistogramaAlunos(data.alunos);\r\n    renderDisciplinas(data.disciplinas);\r\n}\r\n\r\nfunction voltarTurmas() {\r\n    document.getElementById('dashBreadcrumb').style.display   = 'none';\r\n    document.getElementById('dashTurmasPanel').style.display  = '';\r\n    document.getElementById('dashAlunosPanel').style.display  = 'none';\r\n    ['perf','risco','scatter','hist','disc'].forEach(id => destroyChart(id));\r\n}\r\n\r\nfunction renderKPIsTurma(data) {\r\n    const { alunos, stats } = data;\r\n    document.getElementById('kTotalLabel').textContent   = 'Alunos na Turma';\r\n    document.getElementById('kTotal').textContent        = alunos.length;\r\n    document.getElementById('kMediaLabel').textContent   = 'Média da Turma';\r\n    document.getElementById('kMedia').textContent        = stats.media.toFixed(2);\r\n    document.getElementById('kFreqLabel').textContent    = 'Freq. Média';\r\n    document.getElementById('kFreq').textContent         = stats.freq.toFixed(1) + '%';\r\n    document.getElementById('kFreqSub').textContent      = 'mínimo esperado: 75%';\r\n    document.getElementById('kRiscoLabel').textContent   = 'Alunos em Alerta';\r\n    document.getElementById('kRisco').textContent        = stats.em_alerta;\r\n    document.getElementById('kCritico').textContent      = `críticos: ${stats.criticos}`;\r\n    document.getElementById('kAprovacaoLabel').textContent = 'Taxa de Aprovação';\r\n    document.getElementById('kAprovacao').textContent    = stats.taxa_aprovacao.toFixed(1) + '%';\r\n}\r\n\r\n/* ══ Charts de alunos (drill-down) ══ */\r\nfunction renderPerformance(alunos) {\r\n    destroyChart('perf');\r\n    charts.perf = new Chart(document.getElementById('chartPerformance').getContext('2d'), {\r\n        type:'bar',\r\n        data:{\r\n            labels: alunos.map(a=>a.nome.split(' ')[0]),\r\n            datasets:[\r\n                { label:'Média', data:alunos.map(a=>a.media_geral), backgroundColor:'rgba(99,102,241,.75)', borderRadius:6, yAxisID:'yNota' },\r\n                { label:'Frequência (%)', data:alunos.map(a=>a.frequencia_media), backgroundColor:'rgba(16,185,129,.45)', borderRadius:6, yAxisID:'yFreq' },\r\n            ]\r\n        },\r\n        options:{\r\n            responsive:true, maintainAspectRatio:false,\r\n            plugins:{legend:{labels:{color:cc().tick,font:{size:11}}}},\r\n            scales:{\r\n                yNota:{ position:'left',  min:0, max:10,  grid:{color:cc().grid}, ticks:{color:cc().tick}, title:{display:true,text:'Nota',color:cc().tick} },\r\n                yFreq:{ position:'right', min:0, max:100, grid:{display:false}, ticks:{color:cc().tick,callback:v=>v+'%'}, title:{display:true,text:'Frequência',color:cc().tick} },\r\n                x:{ grid:{display:false}, ticks:{color:cc().tick,maxRotation:30} }\r\n            }\r\n        }\r\n    });\r\n}\r\n\r\nfunction renderRisco(alunos) {\r\n    destroyChart('risco');\r\n    const counts = {baixo:0,medio:0,alto:0,critico:0};\r\n    alunos.forEach(a=>{ if(counts[a.risco]!==undefined) counts[a.risco]++; });\r\n    charts.risco = new Chart(document.getElementById('chartRisco').getContext('2d'), {\r\n        type:'doughnut',\r\n        data:{ labels:['Baixo','Médio','Alto','Crítico'],\r\n            datasets:[{ data:[counts.baixo,counts.medio,counts.alto,counts.critico],\r\n                backgroundColor:['#34d399','#fbbf24','#fb7185','#f87171'], borderWidth:0, hoverOffset:10 }] },\r\n        options:{ responsive:true, maintainAspectRatio:false, cutout:'78%', plugins:{legend:{display:false}} }\r\n    });\r\n    const colors=['#34d399','#fbbf24','#fb7185','#f87171'], labels=['Baixo','Médio','Alto','Crítico'], keys=['baixo','medio','alto','critico'];\r\n    document.getElementById('riskLegend').innerHTML = keys.map((k,i)=>\r\n        `<div class=\"legend-item\"><div class=\"legend-dot\" style=\"background:${colors[i]}\"></div>${labels[i]}: ${counts[k]}</div>`).join('');\r\n}\r\n\r\nfunction renderScatter(pontos) {\r\n    destroyChart('scatter');\r\n    if (!pontos?.length) return;\r\n    const cores=['#6366f1','#34d399','#fb7185','#fbbf24','#38bdf8','#a78bfa','#e879f9','#f97316'];\r\n    charts.scatter = new Chart(document.getElementById('chartScatter').getContext('2d'), {\r\n        type:'scatter',\r\n        data:{ datasets: pontos.map((p,i)=>({ label:p.nome.split(' ')[0], data:[{x:p.frequencia,y:p.media}], backgroundColor:cores[i%cores.length], pointRadius:8, pointHoverRadius:11 })) },\r\n        options:{\r\n            responsive:true, maintainAspectRatio:false,\r\n            plugins:{ legend:{labels:{color:cc().tick,font:{size:10},boxWidth:10}}, tooltip:{callbacks:{label:c=>`${c.dataset.label} — freq: ${c.parsed.x}%, nota: ${c.parsed.y}`}} },\r\n            scales:{\r\n                x:{ min:50, max:100, title:{display:true,text:'Frequência (%)',color:cc().tick,font:{size:11}}, grid:{color:cc().grid}, ticks:{color:cc().tick} },\r\n                y:{ min:0,  max:10,  title:{display:true,text:'Média',color:cc().tick,font:{size:11}},         grid:{color:cc().grid}, ticks:{color:cc().tick} }\r\n            }\r\n        }\r\n    });\r\n}\r\n\r\nfunction renderHistograma(dist) {\r\n    destroyChart('hist');\r\n    if (!dist) return;\r\n    const faixas=Object.keys(dist), valores=Object.values(dist), total=valores.reduce((a,b)=>a+b,0)||1;\r\n    charts.hist = new Chart(document.getElementById('chartHistograma').getContext('2d'), {\r\n        type:'bar',\r\n        data:{ labels:faixas, datasets:[{ label:'Alunos', data:valores, backgroundColor:['#f87171','#fb7185','#fbbf24','#34d399','#6366f1'], borderRadius:8 }] },\r\n        options:{\r\n            responsive:true, maintainAspectRatio:false,\r\n            plugins:{ legend:{display:false}, tooltip:{callbacks:{label:c=>`${c.parsed.y} aluno(s) — ${((c.parsed.y/total)*100).toFixed(0)}%`}} },\r\n            scales:{ y:{beginAtZero:true,ticks:{stepSize:1,color:cc().tick},grid:{color:cc().grid}}, x:{grid:{display:false},ticks:{color:cc().tick}} }\r\n        }\r\n    });\r\n}\r\n\r\nfunction renderHistogramaAlunos(alunos) {\r\n    const dist = {'0–2':0,'2–4':0,'4–6':0,'6–8':0,'8–10':0};\r\n    alunos.forEach(a => {\r\n        const m = a.media_geral;\r\n        if      (m < 2) dist['0–2']++;\r\n        else if (m < 4) dist['2–4']++;\r\n        else if (m < 6) dist['4–6']++;\r\n        else if (m < 8) dist['6–8']++;\r\n        else            dist['8–10']++;\r\n    });\r\n    renderHistograma(dist);\r\n}\r\n\r\nfunction renderDisciplinas(disciplinas) {\r\n    destroyChart('disc');\r\n    if (!disciplinas?.length) return;\r\n    charts.disc = new Chart(document.getElementById('chartDisciplinas').getContext('2d'), {\r\n        type:'bar',\r\n        data:{\r\n            labels: disciplinas.map(d=>d.disciplina),\r\n            datasets:[\r\n                { label:'Média', data:disciplinas.map(d=>d.media), backgroundColor:'rgba(99,102,241,.8)', borderRadius:6 },\r\n                { label:'Aprovação (%)', data:disciplinas.map(d=>d.taxa_aprovacao), backgroundColor:'rgba(16,185,129,.55)', borderRadius:6 },\r\n            ]\r\n        },\r\n        options:{\r\n            responsive:true, maintainAspectRatio:false,\r\n            plugins:{ legend:{labels:{color:cc().tick,font:{size:11}}}, tooltip:{callbacks:{afterLabel:c=>{ const d=disciplinas[c.dataIndex]; return d?`  Min: ${d.nota_min?.toFixed(1)} | Max: ${d.nota_max?.toFixed(1)}`:''; }}} },\r\n            scales:{ y:{min:0,max:100,grid:{color:cc().grid},ticks:{color:cc().tick}}, x:{grid:{display:false},ticks:{color:cc().tick}} }\r\n        }\r\n    });\r\n}\r\n\r\nfunction irpColor(irp) {\r\n    if (irp >= 60) return '#fb7185';\r\n    if (irp >= 30) return '#fbbf24';\r\n    return '#34d399';\r\n}\r\n\r\n\r\n/* ══════════════════════════════════\r\n   VIEW: ALUNOS\r\n══════════════════════════════════ */\r\nlet _todosAlunos = [];\r\n\r\nasync function carregarAlunos() {\r\n    const data = await apiFetch('/alunos');\r\n    if (!data) return;\r\n    _todosAlunos = Array.isArray(data) ? data : Object.values(data);\r\n    renderAlunos(_todosAlunos);\r\n}\r\n\r\nfunction renderAlunos(lista) {\r\n    document.getElementById('alunosCount').textContent = `${lista.length} aluno(s) cadastrado(s)`;\r\n    document.getElementById('alunosBody').innerHTML = lista.map(a => `\r\n        <tr>\r\n            <td><strong>${a.nome}</strong></td>\r\n            <td style=\"color:var(--text-dim)\">${a.matricula}</td>\r\n            <td>${a.curso}</td>\r\n            <td>${a.periodo}º</td>\r\n            <td style=\"color:var(--text-dim)\">${a.email || '—'}</td>\r\n            <td>\r\n                <div class=\"btn-group\">\r\n                    <button class=\"btn btn-sm\" onclick=\"abrirModalNota('${a.id}','${a.nome}')\">+ Nota</button>\r\n                    <button class=\"btn btn-sm\" onclick=\"abrirModalFreq('${a.id}','${a.nome}')\">+ Freq.</button>\r\n                </div>\r\n            </td>\r\n        </tr>`).join('');\r\n}\r\n\r\ndocument.getElementById('alunoSearch').addEventListener('input', function() {\r\n    const term = this.value.toLowerCase();\r\n    const filtrados = _todosAlunos.filter(a =>\r\n        a.nome.toLowerCase().includes(term) || a.matricula.includes(term) || a.curso.toLowerCase().includes(term)\r\n    );\r\n    renderAlunos(filtrados);\r\n});\r\n\r\nasync function cadastrarAluno() {\r\n    const nome = document.getElementById('aNome').value.trim();\r\n    const matricula = document.getElementById('aMatricula').value.trim();\r\n    const periodo = parseInt(document.getElementById('aPeriodo').value);\r\n    const curso = document.getElementById('aCurso').value.trim();\r\n    const email = document.getElementById('aEmail').value.trim();\r\n\r\n    if (!nome || !matricula || !curso || !periodo) { alert('Preencha todos os campos obrigatórios.'); return; }\r\n\r\n    const res = await apiFetch('/alunos', { method:'POST', body: JSON.stringify({nome, matricula, periodo, curso, email: email||undefined}) });\r\n    if (res && !res.erro) {\r\n        fecharModal('modalNovoAluno');\r\n        ['aNome','aMatricula','aCurso','aEmail'].forEach(id => document.getElementById(id).value='');\r\n        document.getElementById('aPeriodo').value='2';\r\n        await carregarAlunos();\r\n    } else {\r\n        alert('Erro: ' + (res?.erro || 'Não foi possível cadastrar.'));\r\n    }\r\n}\r\n\r\n/* ══════════════════════════════════\r\n   MODAIS DE NOTA E FREQUÊNCIA\r\n══════════════════════════════════ */\r\nfunction abrirModalNota(alunoId, nome) {\r\n    document.getElementById('notaAlunoId').value = alunoId;\r\n    document.getElementById('notaAlunoNome').textContent = `Aluno: ${nome}`;\r\n    document.getElementById('notaDisciplina').value = '';\r\n    document.getElementById('notaValor').value = '';\r\n    abrirModal('modalNota');\r\n}\r\n\r\nasync function registrarNota() {\r\n    const alunoId = document.getElementById('notaAlunoId').value;\r\n    const disciplina = document.getElementById('notaDisciplina').value.trim();\r\n    const nota = parseFloat(document.getElementById('notaValor').value);\r\n    const periodo = parseInt(document.getElementById('notaPeriodo').value);\r\n    if (!disciplina || isNaN(nota)) { alert('Preencha disciplina e nota.'); return; }\r\n    const res = await apiFetch(`/alunos/${alunoId}/notas`, { method:'POST', body: JSON.stringify({disciplina, nota, periodo}) });\r\n    if (res && !res.erro) { fecharModal('modalNota'); await carregarAlunos(); }\r\n    else { alert('Erro: ' + (res?.erro || 'Falha ao registrar nota.')); }\r\n}\r\n\r\nfunction abrirModalFreq(alunoId, nome) {\r\n    document.getElementById('freqAlunoId').value = alunoId;\r\n    document.getElementById('freqAlunoNome').textContent = `Aluno: ${nome}`;\r\n    document.getElementById('freqDisciplina').value = '';\r\n    document.getElementById('freqValor').value = '';\r\n    abrirModal('modalFreq');\r\n}\r\n\r\nasync function registrarFrequencia() {\r\n    const alunoId = document.getElementById('freqAlunoId').value;\r\n    const disciplina = document.getElementById('freqDisciplina').value.trim();\r\n    const percentual = parseFloat(document.getElementById('freqValor').value);\r\n    const periodo = parseInt(document.getElementById('freqPeriodo').value);\r\n    if (!disciplina || isNaN(percentual)) { alert('Preencha disciplina e frequência.'); return; }\r\n    const res = await apiFetch(`/alunos/${alunoId}/frequencias`, { method:'POST', body: JSON.stringify({disciplina, percentual, periodo}) });\r\n    if (res && !res.erro) { fecharModal('modalFreq'); await carregarAlunos(); }\r\n    else { alert('Erro: ' + (res?.erro || 'Falha ao registrar frequência.')); }\r\n}\r\n\r\n/* ══════════════════════════════════\r\n   VIEW: ALERTAS INTELIGENTES\r\n══════════════════════════════════ */\r\nlet _todosAlertas = [];\r\n\r\nasync function carregarAlertas() {\r\n    const data = await apiFetch('/alertas?periodo=2');\r\n    if (!data) return;\r\n    _todosAlertas = data.alertas || [];\r\n\r\n    const critico = _todosAlertas.filter(a => a.nivel === 'critico').length;\r\n    const alto    = _todosAlertas.filter(a => a.nivel === 'alto').length;\r\n    const medio   = _todosAlertas.filter(a => a.nivel === 'medio').length;\r\n    document.getElementById('aKCritico').textContent = critico;\r\n    document.getElementById('aKAlto').textContent    = alto;\r\n    document.getElementById('aKMedio').textContent   = medio;\r\n\r\n    const badge = document.getElementById('alertBadge');\r\n    const total = _todosAlertas.length;\r\n    if (total > 0) { badge.textContent = total; badge.style.display = 'inline-block'; }\r\n    else { badge.style.display = 'none'; }\r\n\r\n    renderAlertas(_todosAlertas);\r\n}\r\n\r\nfunction filtrarAlertas() {\r\n    const nivel = document.getElementById('alertFiltro').value;\r\n    renderAlertas(nivel ? _todosAlertas.filter(a => a.nivel === nivel) : _todosAlertas);\r\n}\r\n\r\nconst ALERT_ICONS = {\r\n    frequencia:    `<svg width=\"16\" height=\"16\" viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"2\"><circle cx=\"12\" cy=\"12\" r=\"10\"/><polyline points=\"12 6 12 12 16 14\"/></svg>`,\r\n    desempenho:    `<svg width=\"16\" height=\"16\" viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"2\"><polyline points=\"22 12 18 12 15 21 9 3 6 12 2 12\"/></svg>`,\r\n    inconsistencia:`<svg width=\"16\" height=\"16\" viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"2\"><polyline points=\"23 6 13.5 15.5 8.5 10.5 1 18\"/></svg>`,\r\n    comparativo:   `<svg width=\"16\" height=\"16\" viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"2\"><line x1=\"18\" y1=\"20\" x2=\"18\" y2=\"10\"/><line x1=\"12\" y1=\"20\" x2=\"12\" y2=\"4\"/><line x1=\"6\" y1=\"20\" x2=\"6\" y2=\"14\"/></svg>`,\r\n};\r\nconst TIPO_LABEL = { frequencia:'Frequência', desempenho:'Desempenho', inconsistencia:'Inconsistência', comparativo:'Comparativo' };\r\nconst NIVEL_COLOR = { critico: '#f87171', alto: '#fbbf24', medio: '#38bdf8' };\r\nconst NIVEL_BG    = { critico: 'rgba(248,113,113,.08)', alto: 'rgba(251,191,36,.08)', medio: 'rgba(56,189,248,.08)' };\r\n\r\nfunction renderAlertas(lista) {\r\n    const el = document.getElementById('alertasLista');\r\n    if (!lista.length) {\r\n        el.innerHTML = `<div class=\"empty-state\" style=\"padding:3rem\"><svg width=\"40\" height=\"40\" viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"1.5\"><path d=\"M22 11.08V12a10 10 0 1 1-5.93-9.14\"/><polyline points=\"22 4 12 14.01 9 11.01\"/></svg><p>Nenhum alerta encontrado</p></div>`;\r\n        return;\r\n    }\r\n    el.innerHTML = lista.map(a => `\r\n        <div style=\"display:flex;align-items:flex-start;gap:1rem;padding:1rem 0;border-bottom:1px solid var(--glass-border)\">\r\n            <div style=\"width:36px;height:36px;border-radius:10px;background:${NIVEL_BG[a.nivel]};border:1px solid ${NIVEL_COLOR[a.nivel]}33;display:flex;align-items:center;justify-content:center;color:${NIVEL_COLOR[a.nivel]};flex-shrink:0\">\r\n                ${ALERT_ICONS[a.tipo] || ALERT_ICONS.desempenho}\r\n            </div>\r\n            <div style=\"flex:1;min-width:0\">\r\n                <div style=\"display:flex;align-items:center;gap:.6rem;flex-wrap:wrap;margin-bottom:.3rem\">\r\n                    <strong style=\"font-size:.875rem\">${a.aluno_nome}</strong>\r\n                    <span class=\"badge\" style=\"background:${NIVEL_BG[a.nivel]};color:${NIVEL_COLOR[a.nivel]};border:1px solid ${NIVEL_COLOR[a.nivel]}44\">${a.nivel.charAt(0).toUpperCase()+a.nivel.slice(1)}</span>\r\n                    <span style=\"font-size:.7rem;color:var(--text-dim);background:var(--glass-bg);padding:.1rem .5rem;border-radius:6px;border:1px solid var(--glass-border)\">${TIPO_LABEL[a.tipo]||a.tipo}</span>\r\n                </div>\r\n                <div style=\"font-size:.82rem;color:var(--text-dim);margin-bottom:.3rem\">${a.mensagem}</div>\r\n                <div style=\"font-size:.75rem;color:#6366f1\">→ ${a.acao}</div>\r\n            </div>\r\n        </div>`).join('');\r\n}\r\n\r\n/* ══════════════════════════════════\r\n   VIEW: ADMIN — USUÁRIOS\r\n══════════════════════════════════ */\r\nlet _todosUsuarios = [];\r\n\r\nasync function carregarUsuarios() {\r\n    const data = await apiFetch('/admin/usuarios');\r\n    if (!data) return;\r\n    _todosUsuarios = Array.isArray(data) ? data : [];\r\n    document.getElementById('adminCount').textContent = `${_todosUsuarios.length} usuário(s) cadastrado(s)`;\r\n    renderUsuarios(_todosUsuarios);\r\n}\r\n\r\nconst PERFIL_COR = { admin:'icon-rose', coordenador:'icon-violet', professor:'icon-amber', visualizador:'icon-blue' };\r\n\r\nfunction renderUsuarios(lista) {\r\n    document.getElementById('adminBody').innerHTML = lista.map(u => `\r\n        <tr>\r\n            <td><strong>${u.nome}</strong></td>\r\n            <td style=\"color:var(--text-dim)\">${u.matricula}</td>\r\n            <td>\r\n                <select class=\"btn btn-sm\" onchange=\"alterarPerfil('${u.id}', this.value)\" style=\"padding:.25rem .5rem\">\r\n                    ${['visualizador','professor','coordenador','admin'].map(p =>\r\n                        `<option value=\"${p}\" ${u.perfil===p?'selected':''}>${p.charAt(0).toUpperCase()+p.slice(1)}</option>`\r\n                    ).join('')}\r\n                </select>\r\n            </td>\r\n            <td>\r\n                <span class=\"badge ${u.ativo ? 'badge-baixo' : 'badge-alto'}\">${u.ativo ? 'Ativo' : 'Inativo'}</span>\r\n            </td>\r\n            <td>\r\n                <div class=\"btn-group\">\r\n                    <button class=\"btn btn-sm\" onclick=\"toggleAtivo('${u.id}', ${u.ativo})\">${u.ativo ? 'Desativar' : 'Ativar'}</button>\r\n                    <button class=\"btn btn-sm btn-danger\" onclick=\"removerUsuario('${u.id}', '${u.nome}')\">Remover</button>\r\n                </div>\r\n            </td>\r\n        </tr>`).join('');\r\n}\r\n\r\nasync function criarUsuario() {\r\n    const nome      = document.getElementById('uNome').value.trim();\r\n    const matricula = document.getElementById('uMatricula').value.trim();\r\n    const perfil    = document.getElementById('uPerfil').value;\r\n    const senha     = document.getElementById('uSenha').value;\r\n    if (!nome || !matricula || !senha) { alert('Preencha todos os campos obrigatórios.'); return; }\r\n    const res = await apiFetch('/admin/usuarios', { method: 'POST', body: JSON.stringify({ nome, matricula, perfil, senha }) });\r\n    if (res && !res.erro) {\r\n        fecharModal('modalNovoUsuario');\r\n        ['uNome','uMatricula','uSenha'].forEach(id => document.getElementById(id).value = '');\r\n        await carregarUsuarios();\r\n    } else {\r\n        alert('Erro: ' + (res?.erro || 'Não foi possível cadastrar.'));\r\n    }\r\n}\r\n\r\nasync function alterarPerfil(id, perfil) {\r\n    const res = await apiFetch(`/admin/usuarios/${id}`, { method: 'PUT', body: JSON.stringify({ perfil }) });\r\n    if (res && res.erro) alert('Erro: ' + res.erro);\r\n    else await carregarUsuarios();\r\n}\r\n\r\nasync function toggleAtivo(id, ativoAtual) {\r\n    const res = await apiFetch(`/admin/usuarios/${id}`, { method: 'PUT', body: JSON.stringify({ ativo: !ativoAtual }) });\r\n    if (res && res.erro) alert('Erro: ' + res.erro);\r\n    else await carregarUsuarios();\r\n}\r\n\r\nasync function removerUsuario(id, nome) {\r\n    if (!confirm(`Remover o usuário \"${nome}\"? Esta ação não pode ser desfeita.`)) return;\r\n    const res = await apiFetch(`/admin/usuarios/${id}`, { method: 'DELETE' });\r\n    if (res && res.erro) alert('Erro: ' + res.erro);\r\n    else await carregarUsuarios();\r\n}\r\n\r\n/* ══════════════════════════════════\r\n   INICIALIZAÇÃO\r\n══════════════════════════════════ */\r\ndocument.getElementById('themeToggle').addEventListener('click', () => {\r\n    applyTheme(document.documentElement.getAttribute('data-theme') !== 'dark');\r\n});\r\n\r\ndocument.addEventListener('DOMContentLoaded', () => {\r\n    applyTheme(localStorage.getItem('nexus_theme') === 'dark');\r\n\r\n    if (!token()) { window.location.href = '/login'; return; }\r\n    const perfil = localStorage.getItem('nexus_perfil');\r\n    const nome = localStorage.getItem('nexus_nome');\r\n    if (perfil) document.getElementById('userRole').textContent = perfil;\r\n    if (nome) document.getElementById('userName').textContent = nome;\r\n\r\n    if (perfil === 'admin') {\r\n        if (document.getElementById('navAdminSection')) document.getElementById('navAdminSection').style.display = '';\r\n        if (document.getElementById('navAdminItem')) document.getElementById('navAdminItem').style.display = '';\r\n    }\r\n\r\n    document.getElementById('btnLogout').addEventListener('click', e => {\r\n        e.preventDefault();\r\n        localStorage.removeItem('nexus_token');\r\n        localStorage.removeItem('nexus_perfil');\r\n        window.location.href = '/login';\r\n    });\r\n\r\n    showView('dashboard');\r\n    // Carrega contagem de alertas em background para o badge da sidebar\r\n    apiFetch('/alertas?periodo=2').then(data => {\r\n        if (!data) return;\r\n        const total = data.total || 0;\r\n        const badge = document.getElementById('alertBadge');\r\n        if (total > 0) { badge.textContent = total; badge.style.display = 'inline-block'; }\r\n    });\r\n});\r\n\r\n/* ══════════════════════════════════\r\n   IMPORTADOR DE PLANILHA GOOGLE\r\n══════════════════════════════════ */\r\nconst SYSTEM_FIELDS = [\r\n    { key: \"ID_ALUNO\", label: \"Matrícula do Aluno *\", required: true },\r\n    { key: \"NOME_ALUNO\", label: \"Nome do Aluno\", required: false },\r\n    { key: \"NOME_CURSO\", label: \"Nome do Curso *\", required: true },\r\n    { key: \"COD_CURSO\", label: \"Código do Curso\", required: false },\r\n    { key: \"TURMA\", label: \"Turma/Classe *\", required: true },\r\n    { key: \"ANO\", label: \"Ano Letivo *\", required: true },\r\n    { key: \"SEMESTRE\", label: \"Semestre *\", required: true },\r\n    { key: \"SERIE\", label: \"Série/Período Letivo\", required: false },\r\n    { key: \"NOME_DISCIPLINA\", label: \"Nome da Disciplina *\", required: true },\r\n    { key: \"COD_DISCIPLINA\", label: \"Código da Disciplina\", required: false },\r\n    { key: \"MEDIA_FINAL\", label: \"Média Final *\", required: true },\r\n    { key: \"PERC_PRESENCA\", label: \"Frequência/Presença\", required: false },\r\n    { key: \"SITUACAO\", label: \"Situação (Aprovado/Rep_Nota/Rep_Freq)\", required: false },\r\n    { key: \"RISCO_ACADEMICO\", label: \"Risco Acadêmico (Baixo/Medio/Alto)\", required: false },\r\n    { key: \"VA1\", label: \"Nota VA1\", required: false },\r\n    { key: \"VA2\", label: \"Nota VA2\", required: false },\r\n    { key: \"VA3\", label: \"Nota VA3\", required: false },\r\n    { key: \"UNIDADE\", label: \"Unidade/Campus\", required: false },\r\n    { key: \"CIDADE\", label: \"Cidade\", required: false },\r\n    { key: \"ESTADO\", label: \"Estado/UF\", required: false },\r\n    { key: \"SEXO\", label: \"Sexo\", required: false },\r\n    { key: \"DATA_NASCIMENTO\", label: \"Data de Nascimento\", required: false },\r\n    { key: \"IDADE\", label: \"Idade\", required: false },\r\n    { key: \"PROUNI\", label: \"Bolsista Prouni (S/N)\", required: false },\r\n    { key: \"FIES\", label: \"Financiamento FIES (S/N)\", required: false },\r\n    { key: \"BOLSA\", label: \"Outras Bolsas (S/N)\", required: false },\r\n];\r\n\r\nfunction inicializarImportador() {\r\n    document.getElementById('import-step-url').style.display = '';\r\n    document.getElementById('import-loading').style.display = 'none';\r\n    document.getElementById('import-step-mapping').style.display = 'none';\r\n    document.getElementById('import-step-success').style.display = 'none';\r\n    document.getElementById('sheetUrl').value = '';\r\n}\r\n\r\nfunction voltarParaUrl() {\r\n    document.getElementById('import-step-url').style.display = '';\r\n    document.getElementById('import-step-mapping').style.display = 'none';\r\n}\r\n\r\nasync function analisarPlanilha() {\r\n    const url = document.getElementById('sheetUrl').value.trim();\r\n    if (!url) { alert('Insira a URL da planilha pública.'); return; }\r\n    \r\n    document.getElementById('import-step-url').style.display = 'none';\r\n    document.getElementById('import-loading').style.display = '';\r\n    \r\n    const res = await apiFetch('/api/importar/analisar', {\r\n        method: 'POST',\r\n        headers: { 'Content-Type': 'application/json' },\r\n        body: JSON.stringify({ url })\r\n    });\r\n    \r\n    document.getElementById('import-loading').style.display = 'none';\r\n    \r\n    if (res && !res.erro) {\r\n        document.getElementById('tempImportId').value = res.import_id;\r\n        document.getElementById('import-step-mapping').style.display = '';\r\n        \r\n        // Render Mapping fields\r\n        const mappingContainer = document.getElementById('mappingFormFields');\r\n        mappingContainer.innerHTML = SYSTEM_FIELDS.map(field => {\r\n            const suggested = res.sugestoes[field.key] || \"\";\r\n            const optionsHtml = ['<option value=\"\">-- Ignorar --</option>']\r\n                .concat(res.columns.map(col => \r\n                    `<option value=\"${col}\" ${col === suggested ? 'selected' : ''}>${col}</option>`\r\n                )).join('');\r\n                \r\n            return `\r\n                <div class=\"form-group\" style=\"margin-bottom: 0.75rem;\">\r\n                    <label style=\"font-size: 0.78rem; font-weight: 600; display: block; margin-bottom: 0.25rem;\">${field.label}</label>\r\n                    <select id=\"map-${field.key}\" class=\"form-control\" style=\"font-size: 0.8rem; padding: 0.4rem 0.6rem;\">\r\n                        ${optionsHtml}\r\n                    </select>\r\n                </div>`;\r\n        }).join('');\r\n        \r\n        // Render Preview Table\r\n        const thead = document.getElementById('previewTableHead');\r\n        const tbody = document.getElementById('previewTableBody');\r\n        \r\n        thead.innerHTML = `<tr>${res.columns.map(col => `<th style=\"padding: 0.5rem; text-align: left; border-bottom: 1.5px solid var(--glass-border);\">${col}</th>`).join('')}</tr>`;\r\n        tbody.innerHTML = res.preview.map(row => \r\n            `<tr>${res.columns.map(col => `<td style=\"padding: 0.5rem; border-bottom: 1px solid var(--glass-border); max-width: 150px; overflow: hidden; text-overflow: ellipsis; white-space: nowrap;\">${row[col] || \"\"}</td>`).join('')}</tr>`\r\n        ).join('');\r\n        \r\n    } else {\r\n        alert('Erro ao analisar planilha: ' + (res?.erro || 'Verifique se o link está correto e a planilha é pública.'));\r\n        document.getElementById('import-step-url').style.display = '';\r\n    }\r\n}\r\n\r\nasync function confirmarImportacao() {\r\n    const importId = document.getElementById('tempImportId').value;\r\n    \r\n    const mappings = {};\r\n    let missingRequired = false;\r\n    \r\n    SYSTEM_FIELDS.forEach(field => {\r\n        const val = document.getElementById(`map-${field.key}`).value;\r\n        if (field.required && !val) {\r\n            missingRequired = true;\r\n        }\r\n        if (val) {\r\n            mappings[field.key] = val;\r\n        }\r\n    });\r\n    \r\n    if (missingRequired) {\r\n        alert('Por favor, preencha todos os campos obrigatórios marcados com *.');\r\n        return;\r\n    }\r\n    \r\n    if (!confirm('Esta importação irá limpar todos os dados atuais de alunos, disciplinas e registros acadêmicos e substituí-los. Deseja prosseguir?')) {\r\n        return;\r\n    }\r\n    \r\n    document.getElementById('import-step-mapping').style.display = 'none';\r\n    document.getElementById('import-loading').style.display = '';\r\n    \r\n    const res = await apiFetch('/api/importar/confirmar', {\r\n        method: 'POST',\r\n        headers: { 'Content-Type': 'application/json' },\r\n        body: JSON.stringify({ import_id: importId, mappings })\r\n    });\r\n    \r\n    document.getElementById('import-loading').style.display = 'none';\r\n    \r\n    if (res && res.sucesso) {\r\n        document.getElementById('importSuccessMessage').textContent = \r\n            `Sucesso! Importados ${res.alunos_importados} alunos e ${res.registros_importados} registros acadêmicos.`;\r\n        document.getElementById('import-step-success').style.display = '';\r\n    } else {\r\n        alert('Erro ao importar planilha: ' + (res?.erro || 'Erro interno no servidor.'));\r\n        document.getElementById('import-step-mapping').style.display = '';\r\n    }\r\n}\r\n\r\nfunction irParaDashboard() {\r\n    showView('dashboard');\r\n}\r\n</script>\r\n</body>\r\n</html>\r\n
